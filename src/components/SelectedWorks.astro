---
import { Image } from "astro:assets";
import { portfolioProjects } from "../data/home";
---

<div id="selected-works" class="relative">
  <!-- Section-Level Sticky Browser Chrome -->
  <div class="selected-works-chrome">
    <div class="chrome-dots">
      <div class="chrome-dot dot-red"></div>
      <div class="chrome-dot dot-yellow"></div>
      <div class="chrome-dot dot-green"></div>
    </div>
    <div class="chrome-label">vividstack.ca // our work</div>
    <span class="chrome-badge">LIVE SITES</span>
  </div>

  <!-- Centered Header for Mobile -->
  <div class="mobile-section-header w-full text-center pt-8 pb-2 px-4 sm:px-6">
    <span class="text-vivid-navy font-bold uppercase tracking-[0.35em] sm:tracking-[0.4em] text-xs sm:text-sm mb-2 inline-block pb-1 border-b-[3px] border-vivid-mint">Portfolio</span>
    <h2
      class="mobile-works-title font-black uppercase tracking-tighter text-black leading-[0.88] select-none"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      SELECTED <span class="text-vivid-mint">WORK</span>
    </h2>
    <div class="mt-3 w-14 h-1.5 bg-vivid-mint mx-auto shadow-brutalist-navy-chip"></div>
    
    <!-- Mobile Swipe Indicator -->
    <div class="mt-3 flex items-center justify-center gap-2 text-[0.65rem] font-bold uppercase tracking-[0.2em] text-vivid-navy opacity-50">
      <span>Swipe</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 animate-swipe" aria-hidden="true">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </div>
  </div>

  <!-- Desktop: GSAP Pin Wrap | Mobile: Snap Scroll -->
  <div class="pin-wrap" id="pin-wrap">
    <!-- Title card: first slide in the horizontal scroll -->
    <div class="title-card">
      <span class="text-vivid-navy font-bold uppercase tracking-[0.4em] text-sm mb-2 inline-block pb-1 border-b-[3px] border-vivid-mint">Portfolio</span>
      <h2
        class="text-4xl md:text-5xl xl:text-6xl font-black uppercase tracking-tighter text-black leading-[0.88] select-none"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        SELECTED<br /><span class="text-vivid-mint">WORK</span>
      </h2>
      <div class="mt-3 w-16 h-1.5 bg-vivid-mint shadow-brutalist-navy-chip"></div>
    </div>
    {portfolioProjects.map((project) => (
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-card group block">
        <div class="project-card-inner">
          <div class="project-visual-wrap">
            <!-- Dual-Device Container: strictly 16/9 -->
            <div class="dual-device-container">
              <!-- Layer 1 (back): Desktop browser frame + screenshot -->
              <div class="desktop-browser">
                <div class="desktop-browser-frame">
                  <div class="desktop-browser-toolbar" aria-hidden="true">
                    <div class="desktop-browser-dots">
                      <span class="desktop-browser-dot db-dot-red"></span>
                      <span class="desktop-browser-dot db-dot-yellow"></span>
                      <span class="desktop-browser-dot db-dot-green"></span>
                    </div>
                    <div class="desktop-browser-url-wrap">
                      <span class="desktop-browser-url">{project.displayUrl}</span>
                    </div>
                  </div>
                  <div class="desktop-browser-viewport">
                    <Image
                      src={project.image}
                      alt={project.title}
                      class="desktop-screenshot-img"
                      widths={[480, 720, 1200, 1800]}
                      sizes="(max-width: 1023px) min(92vw, 26.5rem), 44vw"
                      loading="lazy"
                      fetchpriority="low"
                      decoding="async"
                      quality={85}
                    />
                  </div>
                </div>
              </div>

              <!-- Layer 2 (front): Mobile Phone -->
              <div class="phone-frame">
                <div class="phone-notch"></div>
                <div class="phone-screen">
                    <Image
                      src={project.mobileImage}
                      alt={`${project.title} mobile`}
                      widths={[320, 390, 520, 780]}
                      sizes="(max-width: 1023px) min(72vw, 17.5rem), 13.2vw"
                    loading="lazy"
                    fetchpriority="low"
                    decoding="async"
                    quality={85}
                  />
                </div>
                <div class="phone-home-bar"></div>
              </div>

              <!-- Accent glow behind the container -->
              <div class="device-glow" style={`background: ${project.accent};`}></div>
            </div>

            <!-- Brutalist CTA — below mockup on all breakpoints (whole card is the link) -->
            <div class="hover-cta">See live site ↗</div>
          </div>

          <!-- Project Metadata — below the 16/9 box -->
          <div class="project-meta">
            <div class="meta-stack">
              <span class="meta-primary">{project.stack}</span>
              <span class="meta-secondary">{project.stack2}</span>
            </div>
            <span class="meta-id">{project.category}</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  /* ============================================
     SELECTED WORKS — Section Chrome Bar
     ============================================ */
  .selected-works-chrome {
    height: 2.625rem;
    background: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    border-bottom: 2px solid var(--color-brutalist);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  @media (max-width: 1023px) {
    .selected-works-chrome {
      height: 3.25rem;
      border-bottom-width: 3px;
    }
  }

  .chrome-dots {
    display: flex;
    gap: 0.375rem;
    align-items: center;
    flex-shrink: 0;
  }

  .chrome-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.1);
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green  { background: #27c93f; }

  .chrome-label {
    flex: 1;
    font-family: 'Inter', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(37,54,68,0.4);
    text-align: center;
  }

  .chrome-badge {
    font-family: 'Inter', sans-serif;
    font-size: 8px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-vivid-mint);
    flex-shrink: 0;
  }

  @media (max-width: 380px) {
    .chrome-badge {
      display: none;
    }

    .chrome-label {
      font-size: 7px;
      letter-spacing: 0.12em;
      padding: 0 0.25rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .chrome-dot {
      width: 8px;
      height: 8px;
    }
  }

  /* Fluid title when mobile header visible */
  .mobile-works-title {
    font-size: clamp(1.625rem, 8vw + 0.25rem, 2.875rem);
  }

  /* ============================================
     SELECTED WORKS — Pin Wrap / Snap Scroll
     ============================================ */
  .pin-wrap {
    display: flex;
    gap: clamp(1.75rem, 3.5vw, 3.25rem);
    padding-left: 4vw;
    /* Extra right padding so GSAP can scroll past “flush end” and center the last project */
    padding-right: min(58vw, 720px);
    align-items: center;
    height: 100vh;
    will-change: transform;
    transform: translateZ(0);
  }

  .title-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: min(32vw, 20rem);
    flex-shrink: 0;
    padding-right: 3vw;
  }

  .mobile-section-header {
    display: none;
  }

  @media (max-width: 1023px) {
    #selected-works {
      height: auto !important;
      overflow: visible !important;
    }

    .pin-wrap {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: max(1rem, env(safe-area-inset-left, 0px))
        max(1rem, env(safe-area-inset-right, 0px));
      -webkit-overflow-scrolling: touch;
      height: auto;
      padding-top: max(0.75rem, env(safe-area-inset-top, 0px));
      padding-bottom: max(1.25rem, env(safe-area-inset-bottom, 0px));
      padding-left: max(1rem, env(safe-area-inset-left, 0px));
      padding-right: max(1rem, env(safe-area-inset-right, 0px));
      gap: clamp(1rem, 4vw, 1.5rem);
      scrollbar-width: none;
      -ms-overflow-style: none;
      transform: none !important;
      align-items: flex-start;
      overscroll-behavior-x: contain;
    }

    .pin-wrap::-webkit-scrollbar { display: none; }

    .title-card { display: none !important; }

    .mobile-section-header { display: block; }
  }

  /* ============================================
     PROJECT CARD SHELL
     ============================================ */
  .project-card {
    flex-shrink: 0;
    width: 55vw;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transform: translateZ(0);
  }

  .project-card-inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  @media (max-width: 1023px) {
    .project-card {
      width: min(85vw, 26.5rem);
      max-width: 100%;
      scroll-snap-align: center;
      scroll-snap-stop: normal;
    }

    .project-card-inner {
      gap: clamp(1rem, 3vw, 1.5rem);
    }
  }

  /* Mockup stack + in-flow CTA (desktop + mobile) */
  .project-visual-wrap {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  /* ============================================
     DUAL DEVICE CONTAINER (16:9)
     ============================================ */
  .dual-device-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    z-index: 1;
  }

  .device-glow {
    position: absolute;
    top: 20%;
    left: 20%;
    right: 20%;
    bottom: 20%;
    filter: blur(100px);
    opacity: 0.15;
    z-index: -1;
    transition: opacity 0.4s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-card:hover .device-glow {
      opacity: 0.25;
    }
  }

  .desktop-browser {
    position: absolute;
    top: 5%;
    left: 0;
    width: 80%;
    height: 90%;
    display: flex;
    flex-direction: column;
    min-height: 0;
    z-index: 2;
    transition: transform 0.3s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-card:hover .desktop-browser {
      transform: translate3d(0, -6px, 0) scale(1.02);
    }
  }

  .desktop-browser-frame {
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 2px solid var(--color-brutalist);
    border-radius: 10px;
    overflow: hidden;
    background: var(--color-white);
    box-shadow: 6px 10px 0 rgba(0, 0, 0, 0.14);
  }

  .desktop-browser-toolbar {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.35rem 0.5rem 0.4rem;
    border-bottom: 2px solid var(--color-brutalist);
    background: var(--color-vivid-panel);
  }

  .desktop-browser-dots {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    flex-shrink: 0;
  }

  .desktop-browser-dot {
    width: clamp(5px, 0.55vw, 8px);
    height: clamp(5px, 0.55vw, 8px);
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.12);
  }

  .db-dot-red {
    background: #ff5f57;
  }
  .db-dot-yellow {
    background: #ffbd2e;
  }
  .db-dot-green {
    background: #27c93f;
  }

  .desktop-browser-url-wrap {
    flex: 1;
    min-width: 0;
    display: flex;
    justify-content: center;
  }

  .desktop-browser-url {
    max-width: 100%;
    padding: 0.15rem 0.45rem;
    border: 1px solid rgba(0, 0, 0, 0.18);
    background: var(--color-white);
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, monospace;
    font-size: clamp(6px, 0.65vw, 9px);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(37, 54, 68, 0.65);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 1023px) {
    .desktop-browser-url {
      font-size: clamp(7px, 2.1vw, 10px);
    }

    .desktop-browser-toolbar {
      padding: 0.28rem 0.4rem 0.32rem;
    }
  }

  .desktop-browser-viewport {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-vivid-cream);
  }

  .desktop-screenshot-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  /* CTA — same mint brutalist bar as phone layout; sits below mockup, above meta */
  .hover-cta {
    position: relative;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    margin-top: 0.5rem;
    padding: 0.65rem 1.125rem;
    border-radius: 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-align: center;
    color: var(--color-vivid-navy);
    background: var(--color-vivid-mint);
    border: 2px solid var(--color-brutalist);
    box-shadow: 4px 4px 0 0 var(--color-brutalist);
    pointer-events: none;
    z-index: 5;
    transition:
      transform 0.2s cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 0.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  @media (hover: hover) and (pointer: fine) {
    .project-card:hover .hover-cta {
      transform: translate(-2px, -2px);
      box-shadow: 6px 6px 0 0 var(--color-brutalist);
    }
  }

  .project-card:active .hover-cta {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 0 var(--color-brutalist);
    transition-duration: 0.1s;
  }

  @media (max-width: 1023px) {
    .hover-cta {
      min-height: 44px;
      padding: 0.625rem 1rem;
      font-size: 0.6875rem;
      letter-spacing: 0.18em;
    }
  }

  /* ============================================
     MOBILE PHONE (Front Layer)
     ============================================ */
  .phone-frame {
    position: absolute;
    bottom: -1%;
    right: 3%;
    width: 24%;
    height: 63%;
    background: #000;
    border-radius: 20px;
    border: 5px solid #333;
    box-shadow: -15px 25px 50px rgba(0,0,0,0.5), inset 0 0 0 2px #000;
    z-index: 3;
    display: flex;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-card:hover .phone-frame {
      transform: translate3d(-12px, -16px, 0) scale(1.04);
    }
  }

  .phone-notch {
    position: absolute;
    top: 0;
    width: 20%;
    height: 12px;
    background: #000;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
    z-index: 4;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 20px;
    background: var(--color-vivid-cream);
  }

  .phone-screenshot-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .phone-home-bar {
    position: absolute;
    bottom: 8px;
    width: 35%;
    height: 4px;
    background: rgba(255,255,255,0.7);
    border-radius: 4px;
    z-index: 4;
  }

  /* —— < lg: stacked mockups (large phone first, full-width desktop strip below) —— */
  @media (max-width: 1023px) {
    .dual-device-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.875rem;
      aspect-ratio: auto;
      padding: 0.35rem 0 0.15rem;
    }

    .device-glow {
      top: 8%;
      left: 5%;
      right: 5%;
      bottom: 8%;
      opacity: 0.12;
    }

    .desktop-browser {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9;
      max-height: none;
      z-index: 2;
      order: 2;
    }

    .desktop-browser-frame {
      box-shadow: 4px 6px 0 rgba(0, 0, 0, 0.12);
    }

    .phone-frame {
      position: relative;
      bottom: auto;
      right: auto;
      order: 1;
      width: min(72vw, 17.5rem);
      max-width: 100%;
      height: auto;
      aspect-ratio: 500 / 749;
      margin: 0 auto;
      border-radius: clamp(18px, 5.5vw, 26px);
      border-width: clamp(4px, 1.1vw, 6px);
      box-shadow:
        0 20px 48px rgba(0, 0, 0, 0.38),
        0 8px 16px rgba(0, 0, 0, 0.12),
        inset 0 0 0 2px #000;
      z-index: 3;
    }

    .phone-notch {
      height: clamp(9px, 2.5vw, 14px);
      border-bottom-left-radius: clamp(8px, 2vw, 12px);
      border-bottom-right-radius: clamp(8px, 2vw, 12px);
    }

    .phone-screen {
      border-radius: inherit;
    }

    .phone-home-bar {
      bottom: clamp(6px, 1.8vw, 10px);
      height: clamp(3px, 0.9vw, 5px);
    }
  }

  @media (max-width: 1023px) and (max-height: 520px) {
    .dual-device-container {
      border-radius: 8px;
      gap: 0.5rem;
    }

    .phone-frame {
      width: min(58vw, 11.5rem);
    }

    .project-card-inner {
      gap: 0.75rem;
    }

    .mobile-section-header {
      padding-top: 1.5rem;
      padding-bottom: 0.35rem;
    }
  }

  /* ============================================
     PROJECT METADATA
     ============================================ */
  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 0.5rem 0.75rem;
    border-top: 1px solid rgba(0,0,0,0.1);
    padding-top: 0.65rem;
  }

  .meta-stack {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-primary {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1rem, 3.4vw, 1.25rem);
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-vivid-navy);
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .meta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.8125rem, 2.8vw, 0.875rem);
    font-weight: 500;
    line-height: 1.35;
    color: rgba(37,54,68,0.6);
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .meta-id {
    font-family: 'Inter', monospace;
    font-size: clamp(0.6rem, 2vw, 0.65rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.5rem;
    background: rgba(37,54,68,0.05);
    color: var(--color-vivid-navy);
    border-radius: 2px;
    flex-shrink: 0;
    align-self: flex-end;
    text-align: center;
    max-width: 100%;
  }

  @media (max-width: 480px) {
    .project-meta {
      flex-direction: column;
      align-items: stretch;
    }

    .meta-stack {
      width: 100%;
    }

    .meta-id {
      align-self: flex-start;
    }
  }

  /* Desktop + prefers-reduced-motion: skip GSAP pin; native horizontal scroll */
  @media (min-width: 1024px) {
    html.reduced-motion #selected-works {
      height: auto !important;
      overflow: visible !important;
    }

    html.reduced-motion .pin-wrap {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      height: auto;
      min-height: min(68vh, 640px);
      padding: 1.5rem 4vw 2.25rem;
      gap: clamp(1.5rem, 3.5vw, 2.75rem);
      padding-right: 12vw;
      transform: none !important;
      will-change: auto;
      align-items: flex-start;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
    }

    html.reduced-motion .pin-wrap::-webkit-scrollbar {
      height: 6px;
    }

    html.reduced-motion .pin-wrap::-webkit-scrollbar-thumb {
      background: rgba(37, 54, 68, 0.25);
      border-radius: 3px;
    }

    html.reduced-motion .pin-wrap .title-card {
      display: flex;
    }

    html.reduced-motion .project-card {
      scroll-snap-align: center;
    }
  }
</style>
