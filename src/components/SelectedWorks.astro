---
import { Image } from "astro:assets";
import { portfolioProjects } from "../data/home";
---

<div id="selected-works" class="relative">
  <!-- Section-Level Sticky Browser Chrome -->
  <div class="selected-works-chrome">
    <div class="chrome-dots">
      <div class="chrome-dot dot-red"></div>
      <div class="chrome-dot dot-yellow"></div>
      <div class="chrome-dot dot-green"></div>
    </div>
    <div class="chrome-label">vividstack.io // our work</div>
    <span class="chrome-badge">CASE STUDIES</span>
  </div>

  <!-- Centered Header for Mobile -->
  <div class="mobile-section-header w-full text-center pt-16 pb-4">
    <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block">Case Studies</span>
    <h2
      class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      SELECTED WORK
    </h2>
    <div class="mt-6 w-16 h-1 bg-black mx-auto"></div>
    
    <!-- Mobile Swipe Indicator -->
    <div class="mt-6 flex items-center justify-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-[#253644] opacity-50">
      <span>Swipe</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 animate-swipe">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </div>
  </div>

  <!-- Desktop: GSAP Pin Wrap | Mobile: Snap Scroll -->
  <div class="pin-wrap" id="pin-wrap">
    <!-- Title card: first slide in the horizontal scroll -->
    <div class="title-card will-change-transform">
      <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-3 block">Case Studies</span>
      <h2
        class="text-6xl xl:text-8xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        SELECTED<br />WORK
      </h2>
      <div class="mt-6 w-20 h-1 bg-black"></div>
    </div>
    {portfolioProjects.map((project) => (
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-card will-change-transform group block">
        <div class="project-card-inner">
          <!-- Dual-Device Container: strictly 16/9 -->
          <div class="dual-device-container">
            <!-- Layer 1 (back): Desktop Browser -->
            <div class="desktop-browser">
              <Image
                src={project.image}
                alt={project.title}
                class="desktop-screenshot-img"
                widths={[600, 1200, 1800]}
                sizes="(max-width: 1024px) 90vw, 60vw"
                loading="lazy"
                decoding="async"
                quality={95}
              />
            </div>

            <!-- Layer 2 (front): Mobile Phone -->
            <div class="phone-frame">
              <div class="phone-notch"></div>
              <div class="phone-screen">
                <Image
                  src={project.mobileImage}
                  alt={`${project.title} mobile`}
                  class="phone-screenshot-img"
                  widths={[390, 780]}
                  sizes="(max-width: 1024px) 30vw, 15vw"
                  loading="lazy"
                  decoding="async"
                  quality={90}
                />
              </div>
              <div class="phone-home-bar"></div>
            </div>

            <!-- Accent glow behind the container -->
            <div class="device-glow" style={`background: ${project.accent};`}></div>
            
            <!-- Unified Hover CTA -->
            <div class="hover-cta">View Case Study ↗</div>
          </div>

          <!-- Project Metadata — below the 16/9 box -->
          <div class="project-meta">
            <div class="meta-stack">
              <span class="meta-primary">{project.stack}</span>
              <span class="meta-secondary">{project.stack2}</span>
            </div>
            <span class="meta-id">{project.systemId}</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  /* ============================================
     SELECTED WORKS — Section Chrome Bar
     ============================================ */
  .selected-works-chrome {
    height: 3rem;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    border-bottom: 2px solid #000;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  @media (max-width: 1023px) {
    .selected-works-chrome {
      height: 4rem;
      border-bottom-width: 3px;
    }
  }

  .chrome-dots {
    display: flex;
    gap: 0.375rem;
    align-items: center;
    flex-shrink: 0;
  }

  .chrome-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.1);
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green  { background: #27c93f; }

  .chrome-label {
    flex: 1;
    font-family: 'Inter', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(37,54,68,0.4);
    text-align: center;
  }

  .chrome-badge {
    font-family: 'Inter', sans-serif;
    font-size: 8px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #95cbd0;
    flex-shrink: 0;
  }

  /* ============================================
     SELECTED WORKS — Pin Wrap / Snap Scroll
     ============================================ */
  .pin-wrap {
    display: flex;
    gap: 6rem;
    padding-left: 5vw;
    /* Extra right padding so GSAP can scroll past “flush end” and center the last project */
    padding-right: min(58vw, 720px);
    align-items: center;
    height: 100vh;
    will-change: transform;
    transform: translateZ(0);
  }

  .title-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 36vw;
    flex-shrink: 0;
    padding-right: 4vw;
  }

  .mobile-section-header {
    display: none;
  }

  @media (max-width: 1023px) {
    #selected-works {
      height: auto !important;
      overflow: visible !important;
    }

    .pin-wrap {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      height: auto;
      padding: 2rem 1.25rem 2rem;
      gap: 1.5rem;
      padding-right: 5vw;
      scrollbar-width: none;
      -ms-overflow-style: none;
      transform: none !important;
      align-items: flex-start;
    }

    .pin-wrap::-webkit-scrollbar { display: none; }

    .title-card { display: none !important; }

    .mobile-section-header { display: block; }
  }

  /* ============================================
     PROJECT CARD SHELL
     ============================================ */
  .project-card {
    flex-shrink: 0;
    width: 55vw;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transform: translateZ(0);
  }

  .project-card-inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (max-width: 1023px) {
    .project-card {
      width: 85vw;
      scroll-snap-align: center;
    }
    .project-card-inner {
      gap: 1.5rem;
    }
  }

  /* ============================================
     DUAL DEVICE CONTAINER (16:9)
     ============================================ */
  .dual-device-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    z-index: 1;
  }

  .device-glow {
    position: absolute;
    top: 20%;
    left: 20%;
    right: 20%;
    bottom: 20%;
    filter: blur(100px);
    opacity: 0.15;
    z-index: -1;
    transition: opacity 0.4s ease;
  }

  .project-card:hover .device-glow {
    opacity: 0.25;
  }

  .desktop-browser {
    position: absolute;
    top: 5%;
    left: 0;
    width: 80%;
    height: 90%;
    display: flex;
    flex-direction: column;
    z-index: 2;
    will-change: transform;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .project-card:hover .desktop-browser {
    transform: translate3d(0, -6px, 0) scale(1.02);
  }

  .desktop-screenshot-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  /* Unified Hover CTA */
  .hover-cta {
    position: absolute;
    bottom: 8%;
    left: 50%;
    transform: translate3d(-50%, 20px, 0);
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    background: #253644;
    color: #fff;
    padding: 12px 28px;
    border-radius: 40px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    z-index: 20;
    pointer-events: none;
    box-shadow: 0 10px 25px -5px rgba(37,54,68,0.5);
  }

  .project-card:hover .hover-cta {
    transform: translate3d(-50%, 0, 0);
    opacity: 1;
  }

  /* ============================================
     MOBILE PHONE (Front Layer)
     ============================================ */
  .phone-frame {
    position: absolute;
    bottom: -1%;
    right: 3%;
    width: 24%;
    height: 63%;
    background: #000;
    border-radius: 20px;
    border: 5px solid #333;
    box-shadow: -15px 25px 50px rgba(0,0,0,0.5), inset 0 0 0 2px #000;
    z-index: 3;
    display: flex;
    justify-content: center;
    overflow: hidden;
    will-change: transform;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .project-card:hover .phone-frame {
    transform: translate3d(-12px, -16px, 0) scale(1.04); /* Parallax pop out */
  }

  .phone-notch {
    position: absolute;
    top: 0;
    width: 20%;
    height: 12px;
    background: #000;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
    z-index: 4;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 20px;
    background: #f8f9fc; /* Light background to blend with transparent PNGs */
  }

  .phone-screenshot-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .phone-home-bar {
    position: absolute;
    bottom: 8px;
    width: 35%;
    height: 4px;
    background: rgba(255,255,255,0.7);
    border-radius: 4px;
    z-index: 4;
  }

  @media (max-width: 1023px) {
    .phone-frame {
      border-radius: 16px;
      border-width: 3px;
      width: 35%;
    }
  }

  /* ============================================
     PROJECT METADATA
     ============================================ */
  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-top: 1px solid rgba(0,0,0,0.1);
    padding-top: 1rem;
  }

  .meta-stack {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-primary {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #253644;
  }

  .meta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(37,54,68,0.6);
  }

  .meta-id {
    font-family: 'Inter', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.5rem;
    background: rgba(37,54,68,0.05);
    color: #253644;
    border-radius: 2px;
  }

  /* Desktop + prefers-reduced-motion: skip GSAP pin; native horizontal scroll */
  @media (min-width: 1024px) {
    html.reduced-motion #selected-works {
      height: auto !important;
      overflow: visible !important;
    }

    html.reduced-motion .pin-wrap {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      height: auto;
      min-height: 75vh;
      padding: 3rem 5vw 4rem;
      gap: 4rem;
      padding-right: 12vw;
      transform: none !important;
      will-change: auto;
      align-items: flex-start;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
    }

    html.reduced-motion .pin-wrap::-webkit-scrollbar {
      height: 6px;
    }

    html.reduced-motion .pin-wrap::-webkit-scrollbar-thumb {
      background: rgba(37, 54, 68, 0.25);
      border-radius: 3px;
    }

    html.reduced-motion .pin-wrap .title-card {
      display: flex;
    }

    html.reduced-motion .project-card {
      scroll-snap-align: center;
    }
  }
</style>
