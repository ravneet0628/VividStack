---
import { Image } from "astro:assets";
import { capabilities } from "../data/home";
import lighthouseImg from "../assets/lighthouse-100.png";
---

<section id="capabilities" class="section-tracer-target relative py-32 bg-vivid-cream bg-grid-tech">
  <div class="section-tracer absolute top-0 left-0 w-full h-px bg-vivid-navy origin-left scale-x-0 z-20"></div>

  <!-- Section heading — constrained -->
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="mb-24 text-center">
      <span class="text-vivid-navy font-bold uppercase tracking-[0.4em] text-sm mb-4 inline-block pb-1.5 border-b-[3px] border-vivid-mint">Technical Edge</span>
      <h2
        class="text-6xl md:text-8xl font-black tracking-tighter uppercase text-vivid-navy leading-[0.85] select-none"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        Capabilities <span class="text-vivid-mint">&</span> Performance
      </h2>
    </div>
  </div>

  <!-- Light Bento Performance Grid -->
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="bento-grid">
      <!-- Main Performance Card -->
      <div class="bento-card bento-perf-main md:col-span-2 md:row-span-2">
        <div class="flex flex-col md:flex-row items-center gap-8 h-full">
          <div class="w-full md:w-1/2 flex justify-center">
            <Image 
              src={lighthouseImg} 
              alt="Lighthouse 100/100 Score" 
              class="bento-image"
              widths={[400, 800]}
              sizes="(max-width: 768px) 100vw, 400px"
              loading="lazy"
              decoding="async"
              quality={85}
            />
          </div>
          <div class="w-full md:w-1/2">
            <span class="card-tag">Proof point</span>
            <h3 class="card-title">Performance: <br/><span class="text-vivid-mint">Sub-second</span> load times</h3>
            <p class="card-text">
              Lighthouse scores like this are the bar we build toward—so real visitors get fast first paint, not just a pretty portfolio screenshot.
            </p>
          </div>
        </div>
      </div>

      <!-- Small Feature Cards -->
      {capabilities.map((item) => (
        <div class="bento-card">
          <h4 class="card-small-title">{item.title}</h4>
          <p class="card-small-text text-vivid-navy/60">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ============================================
     BENTO PERFORMANCE GRID
     ============================================ */
  .bento-card {
    background: var(--color-white);
    border: 2px solid var(--color-vivid-navy);
    padding: 2rem;
    box-shadow: 4px 4px 0 0 rgba(37, 54, 68, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bento-card:hover {
    transform: translateY(-4px);
    box-shadow: 8px 8px 0 0 rgba(37, 54, 68, 0.2);
  }

  .bento-grid > .bento-card:not(.bento-perf-main):hover {
    border-color: var(--color-vivid-mint);
    box-shadow: 8px 8px 0 0 rgba(149, 203, 208, 0.45);
  }

  .bento-perf-main {
    background: var(--color-vivid-navy);
    color: var(--color-white);
    border-color: var(--color-vivid-navy);
    box-shadow: 8px 8px 0 0 var(--color-neon-mint);
  }

  .bento-perf-main:hover {
    box-shadow: 12px 12px 0 0 var(--color-neon-mint);
  }

  .bento-image {
    width: 100%;
    height: auto;
    max-width: 300px;
    filter: drop-shadow(0 20px 30px rgba(0,0,0,0.5));
    transition: transform 0.5s ease;
  }

  .bento-perf-main:hover .bento-image {
    transform: translate3d(0, -6px, 0) scale(1.02);
  }

  .card-tag {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    padding: 0.4rem 0.8rem;
    border: 1px solid rgba(255,255,255,0.2);
    margin-bottom: 1.5rem;
    color: var(--color-neon-mint);
  }

  .card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .card-title {
      font-size: 2.5rem;
    }
  }

  .card-text {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.8);
  }

  .card-small-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-vivid-navy-deep);
    margin-bottom: 0.75rem;
    border-left: 3px solid var(--color-vivid-mint);
    padding-left: 0.75rem;
  }

  .card-small-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    line-height: 1.5;
  }
</style>
