---
import { capabilities } from "../data/home";
---

<section id="capabilities" class="section-tracer-target relative py-12 lg:py-20 bg-vivid-cream bg-grid-tech">
  <div class="section-tracer absolute top-0 left-0 w-full h-px bg-vivid-navy origin-left scale-x-0 z-20"></div>

  <div class="max-w-7xl mx-auto px-5 sm:px-6 relative z-10">
    <header class="mb-6 md:mb-8 text-center">
      <div class="inline-flex flex-col items-center gap-0 mb-3">
        <span
          id="capabilities-eyebrow"
          class="text-vivid-navy font-bold uppercase tracking-[0.4em] text-sm inline-block pb-1.5 opacity-0"
          >How we build</span
        >
        <div class="capabilities-eyebrow-line h-[3px] w-full bg-vivid-mint" aria-hidden="true"></div>
      </div>
      <h2
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter uppercase text-vivid-navy leading-[0.88] select-none"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        <span id="capabilities-title-prefix" class="opacity-0 inline">Speed </span><span
          id="capabilities-title-amp"
          class="text-vivid-mint opacity-0 inline">&</span
        ><span id="capabilities-title-suffix" class="opacity-0 inline"> quality</span>
      </h2>
    </header>

    <div
      class="bento-grid grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 md:auto-rows-[minmax(0,auto)]"
    >
      <div class="bento-card bento-perf-main md:col-span-2 md:row-span-2 min-h-0 opacity-0">
        <div class="flex flex-col md:flex-row md:items-center gap-5 md:gap-6 lg:gap-8 h-full">
          <div class="perf-visual-wrap w-full md:w-[40%] shrink-0 flex justify-center md:justify-start" aria-hidden="true">
            <div class="perf-visual relative w-full max-w-[min(200px,42vw)] aspect-square">
              <svg class="perf-visual-svg w-full h-full" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="100" cy="100" r="92" stroke="rgba(255,255,255,0.08)" stroke-width="2" />
                <circle cx="100" cy="100" r="74" stroke="rgba(255,255,255,0.1)" stroke-width="2" />
                <circle
                  class="perf-gauge-arc"
                  cx="100"
                  cy="100"
                  r="56"
                  stroke="var(--color-neon-mint)"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-dasharray="264 88"
                  transform="rotate(-90 100 100)"
                />
                <path
                  d="M100 36 L100 52 M100 148 L100 164 M36 100 L52 100 M148 100 L164 100"
                  stroke="rgba(255,255,255,0.25)"
                  stroke-width="2"
                  stroke-linecap="square"
                />
              </svg>
              <div class="perf-visual-label absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                <span class="perf-visual-metric font-black text-white tracking-tighter leading-none" style="font-family: 'Space Grotesk', sans-serif;">&lt;1s</span>
              </div>
            </div>
          </div>
          <div class="w-full md:flex-1 min-w-0">
            <span class="card-tag">Core Web Vitals</span>
            <h3 class="card-title"><span class="text-vivid-mint">Sub-second</span> load times</h3>
            <p class="card-text">
              Quick loads mean fewer bounces before someone calls or books. We build to Core Web Vitals and keep LCP under about a second on the pages that matter.
            </p>
          </div>
        </div>
      </div>

      {capabilities.map((item) => (
        <div class="bento-card bento-satellite min-h-0 opacity-0">
          <h4 class="card-small-title">{item.title}</h4>
          <p class="card-small-text text-vivid-navy/60">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ============================================
     BENTO PERFORMANCE GRID
     ============================================ */
  .bento-card {
    background: var(--color-white);
    border: 2px solid var(--color-vivid-navy);
    padding: clamp(1rem, 3vw, 1.35rem);
    box-shadow: 4px 4px 0 0 rgba(37, 54, 68, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bento-card:hover {
    transform: translateY(-4px);
    box-shadow: 8px 8px 0 0 rgba(37, 54, 68, 0.2);
  }

  .bento-grid > .bento-card:not(.bento-perf-main):hover {
    border-color: var(--color-vivid-mint);
    box-shadow: 8px 8px 0 0 rgba(149, 203, 208, 0.45);
  }

  .bento-perf-main {
    background: var(--color-vivid-navy);
    color: var(--color-white);
    border-color: var(--color-vivid-navy);
    box-shadow: 8px 8px 0 0 var(--color-neon-mint);
  }

  .bento-perf-main:hover {
    box-shadow: 12px 12px 0 0 var(--color-neon-mint);
  }

  .perf-visual-metric {
    font-size: clamp(2.25rem, 7vw, 3rem);
  }

  .bento-perf-main:hover .perf-visual {
    transform: translate3d(0, -4px, 0);
  }

  .perf-visual {
    transition: transform 0.45s ease;
  }

  .card-tag {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    padding: 0.35rem 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    margin-bottom: 0.65rem;
    color: var(--color-neon-mint);
  }

  .card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .card-title {
      font-size: 1.875rem;
    }
  }

  .card-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.8);
  }

  .card-small-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-vivid-navy-deep);
    margin-bottom: 0.5rem;
    border-left: 3px solid var(--color-vivid-mint);
    padding-left: 0.75rem;
  }

  .card-small-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    line-height: 1.45;
  }
</style>
