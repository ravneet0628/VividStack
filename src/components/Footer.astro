---
// Footer component
---

<div class="bg-vivid-navy border-t border-vivid-cream/10 py-8 md:py-10">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="text-xs text-vivid-cream/40 uppercase tracking-[0.25em] text-center md:text-left">
      © 2026 VividStack. All rights reserved.
    </div>
    <nav class="flex flex-wrap gap-2 sm:gap-4 justify-center md:justify-end text-xs text-vivid-cream/55 uppercase tracking-[0.18em]" aria-label="Legal">
      <a href="/privacy/" class="footer-legal-link">Privacy Policy</a>
      <a href="/terms/" class="footer-legal-link">Terms of Service</a>
    </nav>
  </div>
</div>

<style>
  .footer-legal-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0.5rem 0.75rem;
    margin: -0.5rem -0.25rem;
    border-radius: 2px;
    text-decoration: none;
    font: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    color: inherit;
    transition: color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .footer-legal-link:hover {
    color: var(--color-vivid-teal);
  }

  .footer-legal-link:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-vivid-cream), 0 0 0 4px var(--color-vivid-teal);
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-legal-link {
      transition-duration: 0.01s;
    }
  }
</style>
