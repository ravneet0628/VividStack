---
import { Image } from "astro:assets";
import heroCode from "../assets/hero_code.png";
---

<section
    class="relative z-0 min-h-screen flex items-center justify-center bg-vivid-cream overflow-hidden text-center px-6"
  >
  <div
    id="ambient-elements"
    class="absolute inset-0 pointer-events-none z-[-1] opacity-5"
  >
    <div
      class="absolute top-[8%] left-[5%] w-48 h-48 md:w-64 md:h-64 text-vivid-navy -rotate-12"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="0.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-full h-full"
        aria-hidden="true"
      >
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
        <line x1="2" y1="20" x2="22" y2="20"></line>
      </svg>
    </div>
    <div
      class="absolute top-[35%] right-[2%] text-[24rem] font-mono leading-none text-vivid-navy rotate-[-15deg] select-none opacity-5"
      aria-hidden="true"
    >
      &#123;
    </div>
    <div
      class="absolute bottom-[20%] right-[15%] text-[24rem] font-mono leading-none text-vivid-navy rotate-[15deg] select-none opacity-5"
      aria-hidden="true"
    >
      &#125;
    </div>
    <div
      class="absolute bottom-[10%] left-[15%] w-72 h-72 border border-vivid-navy rotate-45 flex items-center justify-center"
      aria-hidden="true"
    >
      <div class="w-full h-[1px] bg-vivid-navy"></div>
      <div class="absolute h-full w-[1px] bg-vivid-navy"></div>
      <div class="absolute w-2/3 h-2/3 border border-vivid-navy"></div>
    </div>
  </div>

  <!-- Hero Code Structure Watermark -->
  <div
    id="hero-background"
    class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 w-[200vw] md:w-[85vw] max-w-[1200px] opacity-10 md:opacity-[0.03] pointer-events-none z-[-1] transition-opacity duration-1000"
  >
    <Image
      src={heroCode}
      alt=""
      class="w-full h-auto grayscale opacity-40 md:opacity-100"
      widths={[640, 960, 1200, 1600]}
      sizes="(max-width: 768px) 100vw, min(85vw, 1200px)"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      quality={82}
    />
  </div>

  <!-- Ultra-lightweight Digital Structure Nodes -->
  <div
    class="absolute inset-0 pointer-events-none overflow-hidden mix-blend-multiply hidden md:block"
  >
    <!-- Mint Orb — static opacity (no pulse) to avoid repaints on large blurred layers -->
    <div
      class="absolute -top-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full bg-vivid-mint/[0.05] blur-[100px]"
    >
    </div>
    <!-- Core Navy Node -->
    <div
      class="absolute top-[40%] -left-[15%] w-[50vw] h-[50vw] rounded-full bg-vivid-navy/[0.03] blur-[140px]"
    >
    </div>
    <!-- Center Anchor -->
    <div
      class="absolute top-[20%] left-[30%] w-[30vw] h-[30vw] rounded-full bg-vivid-navy/[0.03] blur-[80px]"
    >
    </div>
  </div>

  <!-- Floating Brutalist Tech Nodes -->
  <div
    class="tech-node absolute top-[12%] sm:top-[30%] md:top-[40%] left-[4%] md:left-[8%] bg-white/95 backdrop-blur-sm border border-vivid-navy p-2 md:p-5 rounded-none shadow-brutalist-navy-sm md:shadow-brutalist-navy-lg w-36 md:w-52 text-left opacity-0 flex flex-col scale-90 md:scale-100"
  >
    <div
      class="flex items-center gap-3 mb-2 border-b border-vivid-navy/10 pb-3"
    >
      <div
        class="w-3 h-3 rounded-none bg-vivid-mint shadow-brutalist-navy-2xs"
      >
      </div>
      <span
        class="text-[0.65rem] font-bold uppercase tracking-[0.25em] text-vivid-navy"
        >Projects Shipped</span
      >
    </div>
    <div class="text-vivid-navy text-2xl md:text-3xl font-black tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">
      4+
    </div>
  </div>

  <div
    class="tech-node absolute bottom-[8%] sm:bottom-[15%] md:bottom-[18%] right-[6%] md:right-[12%] bg-vivid-navy border border-vivid-navy p-3 md:p-6 rounded-none shadow-brutalist-mint-md md:shadow-brutalist-mint-lg w-40 md:w-64 text-left opacity-0 flex flex-col scale-90 md:scale-100"
  >
    <div class="flex justify-between items-center mb-4">
      <div
        class="text-[0.65rem] font-bold uppercase tracking-widest text-white/50"
      >
        Page Load Time
      </div>
      <div class="text-vivid-mint font-bold text-sm" style="font-family: 'Space Grotesk', sans-serif;">&lt; 1 sec</div>
    </div>
    <div
      class="w-full bg-white/5 h-2 rounded-none overflow-hidden border border-white/10"
    >
      <div class="w-[95%] bg-vivid-mint h-full border-r border-black"></div>
    </div>
  </div>

  <div
    class="tech-node absolute top-[18%] right-[4%] lg:right-[5%] bg-white backdrop-blur-md border border-vivid-navy p-4 rounded-none shadow-brutalist-navy-xl hidden lg:flex items-center gap-5 opacity-0"
  >
    <div
      class="w-10 h-10 flex items-center justify-center bg-vivid-navy text-vivid-mint text-base font-black shadow-brutalist-mint-sm" style="font-family: 'Space Grotesk', sans-serif;"
    >
      100
    </div>
    <div class="flex flex-col">
      <span
        class="text-[0.65rem] font-bold uppercase tracking-[0.3em] text-vivid-navy"
        >Lighthouse</span
      >
      <span
        class="text-[0.6rem] font-bold uppercase tracking-[0.2em] text-vivid-navy/40"
        >Perfect Score</span
      >
    </div>
  </div>

  <div class="z-10 w-full max-w-7xl mx-auto flex flex-col items-center">
    <div id="hero-brand" class="mb-4">
      <h1
        class="text-6xl sm:text-8xl md:text-[7rem] lg:text-[9rem] font-extrabold tracking-tighter uppercase leading-none drop-shadow-sm flex flex-wrap justify-center gap-x-[2vw]"
      >
        <span class="text-vivid-navy flex">
          {
            "Vivid"
              .split("")
              .map((char) => (
                <span class="hero-char inline-block opacity-0">{char}</span>
              ))
          }
        </span>
        <span class="text-vivid-mint flex">
          {
            "Stack"
              .split("")
              .map((char) => (
                <span class="hero-char inline-block opacity-0">{char}</span>
              ))
          }
        </span>
      </h1>
    </div>
    <h2
      id="hero-title"
      class="text-lg sm:text-xl md:text-2xl font-bold tracking-[0.2em] text-vivid-navy uppercase opacity-0 mt-2"
    >
      WE BUILD WEBSITES THAT <span class="text-vivid-mint">WIN CUSTOMERS.</span>
    </h2>

    <p
      id="hero-subtitle"
      class="mt-8 md:mt-10 text-base sm:text-xl md:text-2xl lg:text-3xl text-vivid-navy/70 font-medium tracking-wide opacity-0 max-w-3xl px-2"
    >
      Beautiful, fast websites for businesses that want to grow.
    </p>

    <div id="hero-cta" class="mt-12 md:mt-16 opacity-0">
      <a
        href="#selected-works"
        class="group btn-brutalist-primary hover:pr-14"
      >
        <span
          class="relative z-10 font-bold uppercase tracking-[0.2em] md:tracking-[0.25em] text-sm md:text-base"
          >See Our Work</span
        >
        <div
          class="absolute right-5 translate-x-10 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 font-bold text-lg text-vivid-mint"
        >
          →
        </div>
      </a>
    </div>
  </div>
  </section>
