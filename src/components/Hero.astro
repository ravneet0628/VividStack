---
import { Image } from "astro:assets";
import heroCode from "../assets/hero_code.png";
---

<section
    class="relative z-0 isolate flex min-h-[100dvh] min-h-screen flex-col bg-vivid-cream overflow-hidden text-center"
  >
  <div
    id="ambient-elements"
    class="absolute inset-0 pointer-events-none z-[-1] opacity-5 overflow-hidden"
  >
    <div
      class="absolute top-[8%] left-[5%] w-48 h-48 md:w-64 md:h-64 text-vivid-navy -rotate-12"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="0.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-full h-full"
        aria-hidden="true"
      >
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
        <line x1="2" y1="20" x2="22" y2="20"></line>
      </svg>
    </div>
    <div
      class="absolute top-[35%] right-[2%] text-[24rem] font-mono leading-none text-vivid-navy rotate-[-15deg] select-none opacity-5"
      aria-hidden="true"
    >
      &#123;
    </div>
    <div
      class="absolute bottom-[20%] right-[15%] text-[24rem] font-mono leading-none text-vivid-navy rotate-[15deg] select-none opacity-5"
      aria-hidden="true"
    >
      &#125;
    </div>
    <div
      class="absolute bottom-[10%] left-[15%] w-72 h-72 border border-vivid-navy rotate-45 flex items-center justify-center"
      aria-hidden="true"
    >
      <div class="w-full h-[1px] bg-vivid-navy"></div>
      <div class="absolute h-full w-[1px] bg-vivid-navy"></div>
      <div class="absolute w-2/3 h-2/3 border border-vivid-navy"></div>
    </div>
  </div>

  <!-- Hero Code Structure Watermark — clip so w-[200vw] cannot widen the document -->
  <div
    class="pointer-events-none absolute inset-0 z-[-1] overflow-hidden"
    aria-hidden="true"
  >
    <div
      id="hero-background"
      class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 w-[200vw] md:w-[85vw] max-w-[1200px] opacity-10 md:opacity-[0.03] transition-opacity duration-1000"
    >
      <Image
        src={heroCode}
        alt=""
        class="w-full h-auto grayscale opacity-40 md:opacity-100"
        widths={[640, 960, 1200, 1600]}
        sizes="(max-width: 768px) 100vw, min(85vw, 1200px)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        quality={82}
      />
    </div>
  </div>

  <!-- Ultra-lightweight Digital Structure Nodes -->
  <div
    class="absolute inset-0 pointer-events-none overflow-hidden mix-blend-multiply hidden md:block"
  >
    <!-- Mint Orb — static opacity (no pulse) to avoid repaints on large blurred layers -->
    <div
      class="absolute -top-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full bg-vivid-mint/[0.05] blur-[100px]"
    >
    </div>
    <!-- Core Navy Node -->
    <div
      class="absolute top-[40%] -left-[15%] w-[50vw] h-[50vw] rounded-full bg-vivid-navy/[0.03] blur-[140px]"
    >
    </div>
    <!-- Center Anchor -->
    <div
      class="absolute top-[20%] left-[30%] w-[30vw] h-[30vw] rounded-full bg-vivid-navy/[0.03] blur-[80px]"
    >
    </div>
  </div>

  <!-- Projects stat: phone = top band under fixed nav; md+ = mid-left -->
  <div
    class="tech-node pointer-events-none absolute max-md:top-[max(10rem,calc(4rem+env(safe-area-inset-top,0px)+0.75rem))] max-md:bottom-auto max-md:translate-y-0 md:top-[58%] md:bottom-auto md:-translate-y-1/2 left-[4%] md:left-[7%] z-[1] w-auto max-w-[min(11rem,42vw)] opacity-0 flex items-stretch gap-0 border border-vivid-navy bg-white/90 backdrop-blur-sm shadow-brutalist-navy-sm md:shadow-brutalist-navy-md"
  >
    <div
      class="w-1 shrink-0 bg-vivid-mint shadow-brutalist-navy-2xs"
      aria-hidden="true"
    >
    </div>
    <div class="flex items-center gap-2.5 pl-2.5 pr-3 py-2 md:pl-3 md:pr-3.5 md:py-2.5">
      <span
        class="text-vivid-navy text-lg md:text-xl font-black tabular-nums leading-none tracking-tight shrink-0"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        4+
      </span>
      <span
        class="text-[0.5rem] md:text-[0.55rem] font-bold uppercase leading-snug tracking-[0.18em] text-vivid-navy/65 text-left"
      >
        Projects<br aria-hidden="true" /> shipped
      </span>
    </div>
  </div>

  <div
    class="tech-node pointer-events-none absolute max-md:top-[max(10rem,calc(4rem+env(safe-area-inset-top,0px)+0.75rem))] max-md:bottom-auto max-md:w-[min(9.75rem,calc(50vw-1.5rem))] md:top-auto md:bottom-[18%] md:w-64 right-[4%] sm:right-[6%] md:right-[12%] bg-vivid-navy border border-vivid-navy p-2.5 md:p-6 rounded-none shadow-brutalist-mint-md md:shadow-brutalist-mint-lg text-left opacity-0 flex flex-col scale-90 md:scale-100"
  >
    <div class="flex justify-between items-center gap-1.5 mb-2 md:mb-4">
      <div
        class="text-[0.55rem] max-md:leading-tight md:text-[0.65rem] font-bold uppercase tracking-widest text-white/50"
      >
        Page Load Time
      </div>
      <div class="text-vivid-mint font-bold text-xs md:text-sm shrink-0" style="font-family: 'Space Grotesk', sans-serif;">&lt; 1 sec</div>
    </div>
    <div
      class="w-full bg-white/5 h-2 rounded-none overflow-hidden border border-white/10"
    >
      <div class="w-[95%] bg-vivid-mint h-full border-r border-black"></div>
    </div>
  </div>

  <div
    class="tech-node absolute top-[18%] right-[4%] lg:right-[5%] bg-white backdrop-blur-md border border-vivid-navy p-2.5 rounded-none shadow-brutalist-navy-md hidden lg:flex items-center gap-3 opacity-0"
  >
    <div
      class="w-8 h-8 flex shrink-0 items-center justify-center bg-vivid-navy text-vivid-mint text-sm font-black shadow-brutalist-mint-sm"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      100
    </div>
    <div class="flex flex-col gap-0.5">
      <span
        class="text-[0.55rem] font-bold uppercase tracking-[0.22em] text-vivid-navy"
        >Lighthouse</span
      >
      <span
        class="text-[0.5rem] font-bold uppercase tracking-[0.18em] text-vivid-navy/40"
        >Perfect Score</span
      >
    </div>
  </div>

  <!-- Mobile-only layout fix: drop the old 15rem top pad; use same nav + safe-area inset as desktop so the hero stack centers in the viewport and sits closer to the stat row. -->
  <div
    class="relative z-10 flex w-full flex-1 flex-col px-6 pb-[max(1.25rem,env(safe-area-inset-bottom,0px))] pt-[calc(4.5rem+env(safe-area-inset-top,0px))] md:pb-10"
  >
    <div
      class="mx-auto flex w-full max-w-7xl min-h-0 flex-1 flex-col items-center justify-center py-2 md:py-4"
    >
    <p
      id="hero-eyebrow"
      class="mb-3 md:mb-5 text-[0.65rem] sm:text-xs md:text-sm font-bold uppercase tracking-[0.22em] sm:tracking-[0.25em] text-vivid-navy/75 opacity-0 text-center max-w-3xl px-4 leading-relaxed"
    >
      <span class="inline-flex tracking-tight">
        <span class="text-vivid-navy">Vivid</span><span class="text-vivid-mint"
          >Stack</span
        >
      </span>
      <span class="text-vivid-navy/40 mx-1.5" aria-hidden="true">·</span>
      <span class="text-vivid-navy/90">Web design for growing businesses</span>
    </p>
    <div id="hero-brand" class="mb-0 w-full px-1">
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-[5.25rem] font-extrabold tracking-tighter uppercase leading-[1.05] drop-shadow-sm flex flex-wrap justify-center gap-x-[0.35em] gap-y-2 text-center mx-auto"
      >
        <span class="text-vivid-navy inline-block text-center">
          {
            "We build websites that "
              .split("")
              .map((char) => (
                <span class="hero-char inline-block whitespace-pre opacity-0"
                  >{char}</span
                >
              ))
          }
        </span>
        <span class="text-vivid-mint inline-block text-center">
          {
            "win customers"
              .split("")
              .map((char) => (
                <span class="hero-char inline-block whitespace-pre opacity-0"
                  >{char}</span
                >
              ))
          }
        </span>
      </h1>
    </div>

    <p
      id="hero-subtitle"
      class="mt-6 md:mt-8 text-base sm:text-xl md:text-2xl lg:text-3xl text-vivid-navy/70 font-medium tracking-wide opacity-0 max-w-3xl px-2"
    >
      Fast, mobile-ready sites that help you look professional, get found on
      Google, and keep ongoing costs low.
    </p>

    <div id="hero-cta" class="mt-8 max-md:mt-10 md:mt-16 opacity-0">
      <a
        href="#selected-works"
        class="group btn-brutalist-primary hover:pr-14"
      >
        <span
          class="relative z-10 font-bold uppercase tracking-[0.2em] md:tracking-[0.25em] text-sm md:text-base"
          >See Our Work</span
        >
        <div
          class="absolute right-5 translate-x-10 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 font-bold text-lg text-vivid-mint"
        >
          →
        </div>
      </a>
    </div>
    </div>
  </div>
  </section>
