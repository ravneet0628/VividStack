---
import { Image } from "astro:assets";
import logo from "../assets/Vivid-stack-logo.png";
---

<nav id="main-nav" class="nav-container" aria-label="Primary">
  <!-- Brand: logo + wordmark -->
  <a href="/" class="brand-link" id="nav-brand-link">
    <div class="logo-wrapper">
      <Image
        src={logo}
        alt="VividStack logo"
        width={160}
        height={160}
        class="logo-img"
        widths={[80, 112, 160]}
        sizes="40px"
        loading="eager"
        fetchpriority="high"
        quality={95}
      />
    </div>
    <span class="brand-name">
      <span class="brand-vivid">VIVID</span><span class="brand-stack">STACK</span>
    </span>
  </a>

  <!-- Mobile hamburger — 48px touch target (WCAG minimum 44px) -->
  <button
    type="button"
    id="mobile-menu-btn"
    class="mobile-menu-btn"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-links"
  >
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>

  <!-- Dark backdrop overlay — tap to dismiss -->
  <div id="nav-backdrop" class="nav-backdrop"></div>

  <!-- Nav links (mobile: dialog role + focus trap while open) -->
  <div class="nav-links" id="nav-links">
    <a href="/" class="nav-link">Home</a>
    <a href="#advantage" class="nav-link">Advantage</a>
    <a href="#services" class="nav-link">Services</a>
    <a href="#platform" class="nav-link">Work</a>
    <a href="#contact" class="contact-btn">Contact Us</a>
  </div>
</nav>

<script>
  const MOBILE_MAX = 767;

  const btn = document.getElementById("mobile-menu-btn");
  const links = document.getElementById("nav-links");
  const backdrop = document.getElementById("nav-backdrop");
  const brandLink = document.getElementById("nav-brand-link");

  let menuTrapHandler = /** @type {null | ((e: KeyboardEvent) => void)} */ (null);
  let menuOpenSnapshot = /** @type {HTMLElement | null} */ (null);

  function isMobileNav() {
    return window.innerWidth <= MOBILE_MAX;
  }

  /**
   * @returns {HTMLElement[]}
   */
  function drawerFocusables() {
    if (!btn || !links) return [];
    const anchors = Array.from(links.querySelectorAll("a.nav-link, a.contact-btn"));
    return /** @type {HTMLElement[]} */ ([btn, ...anchors]);
  }

  function openMenu() {
    btn?.classList.add("active");
    btn?.setAttribute("aria-expanded", "true");
    btn?.setAttribute("aria-label", "Close menu");
    links?.classList.add("active");
    backdrop?.classList.add("active");
    document.body.style.overflow = "hidden";

    if (!isMobileNav()) return;

    menuOpenSnapshot =
      document.activeElement instanceof HTMLElement ? document.activeElement : null;

    brandLink?.setAttribute("tabindex", "-1");
    document.getElementById("main-content")?.setAttribute("inert", "");

    links?.setAttribute("role", "dialog");
    links?.setAttribute("aria-modal", "true");
    links?.setAttribute("aria-label", "Site navigation");

    const firstLink = links?.querySelector("a.nav-link, a.contact-btn");
    if (firstLink instanceof HTMLElement) firstLink.focus();

    menuTrapHandler = /** @param {KeyboardEvent} e */ (e) => {
      if (e.key !== "Tab" || !btn?.classList.contains("active")) return;
      const list = drawerFocusables();
      if (list.length === 0) return;
      const active = document.activeElement;
      const idx = active instanceof HTMLElement ? list.indexOf(active) : -1;
      if (idx === -1) return;

      if (!e.shiftKey && idx === list.length - 1) {
        e.preventDefault();
        const wrap = list[0];
        if (wrap instanceof HTMLElement) wrap.focus();
      } else if (e.shiftKey && idx === 0) {
        e.preventDefault();
        const wrap = list[list.length - 1];
        if (wrap instanceof HTMLElement) wrap.focus();
      }
    };
    document.addEventListener("keydown", menuTrapHandler);
  }

  function closeMenu() {
    btn?.classList.remove("active");
    btn?.setAttribute("aria-expanded", "false");
    btn?.setAttribute("aria-label", "Open menu");
    links?.classList.remove("active");
    backdrop?.classList.remove("active");
    document.body.style.overflow = "";

    brandLink?.removeAttribute("tabindex");
    document.getElementById("main-content")?.removeAttribute("inert");

    links?.removeAttribute("role");
    links?.removeAttribute("aria-modal");
    links?.removeAttribute("aria-label");

    if (menuTrapHandler) {
      document.removeEventListener("keydown", menuTrapHandler);
      menuTrapHandler = null;
    }

    if (menuOpenSnapshot && document.contains(menuOpenSnapshot)) {
      menuOpenSnapshot.focus();
    } else {
      btn?.focus();
    }
    menuOpenSnapshot = null;
  }

  btn?.addEventListener("click", () => {
    const isOpen = btn.classList.contains("active");
    isOpen ? closeMenu() : openMenu();
  });

  backdrop?.addEventListener("click", closeMenu);

  links?.querySelectorAll(".nav-link, .contact-btn").forEach((link) => {
    link.addEventListener("click", () => {
      if (isMobileNav()) closeMenu();
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && btn?.classList.contains("active")) {
      closeMenu();
    }
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth > MOBILE_MAX && btn?.classList.contains("active")) {
      closeMenu();
    }
  });
</script>

<style>
  /* ── Scroll-driven background: pure CSS, zero JS, zero flicker ─────────── */
  @keyframes nav-fill {
    from {
      background: rgba(248, 249, 250, 0);
      box-shadow: none;
    }
    to {
      background: rgba(248, 249, 250, 0.88);
      box-shadow: 0 1px 20px rgba(37, 54, 68, 0.07);
    }
  }

  .nav-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 9999;
    /* Standard navbar height — 64px, no scroll resize */
    height: 64px;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;

    /* Single always-on compositor layer — never create/destroy */
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);

    /* Pure CSS scroll-driven fade — no JS at all */
    animation: nav-fill linear both;
    animation-timeline: scroll(root block);
    animation-range: 0px 80px;
  }

  @media (min-width: 768px) {
    .nav-container {
      padding: 0 3rem;
    }
  }

  /* ── Brand (logo + wordmark) ────────────────────────────────────────────── */
  .brand-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    flex-shrink: 0;
    border-radius: 2px;
  }

  .brand-link:focus-visible {
    outline: 2px solid var(--color-vivid-navy);
    outline-offset: 3px;
  }

  .logo-wrapper {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .logo-wrapper {
      width: 56px;
      height: 56px;
    }
  }

  .logo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-name {
    font-size: 1rem;
    font-weight: 800;
    /* tracking-tighter = -0.05em, matches hero h1 */
    letter-spacing: -0.05em;
    text-transform: uppercase;
    line-height: 1;
    display: flex;
  }

  @media (min-width: 768px) {
    .brand-name {
      font-size: 1.1rem;
    }
  }

  /* "Vivid" — navy, same as hero */
  .brand-vivid {
    color: var(--color-vivid-navy);
  }

  /* "Stack" — mint accent, same as hero */
  .brand-stack {
    color: var(--color-vivid-mint);
  }

  /* ── Mobile hamburger — 48px touch target ─────────────────────────────── */
  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    /* 48px = above WCAG 44px minimum for touch targets */
    width: 48px;
    height: 48px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.75rem;
    gap: 5px;
    border-radius: 2px;
    -webkit-tap-highlight-color: transparent;
    /* Ensure it appears above the backdrop */
    position: relative;
    z-index: 60;
  }

  .mobile-menu-btn:focus-visible {
    outline: 2px solid var(--color-vivid-navy);
    outline-offset: 2px;
  }

  .hamburger-line {
    width: 1.4rem;
    height: 2px;
    background: var(--color-vivid-navy);
    border-radius: 1px;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  .mobile-menu-btn.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(4px, 5px);
  }
  .mobile-menu-btn.active .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .mobile-menu-btn.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -5px);
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  /* ── Backdrop overlay — dark scrim behind mobile menu ──────────────────── */
  .nav-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(37, 54, 68, 0.5);
    z-index: 50;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    -webkit-tap-highlight-color: transparent;
  }

  .nav-backdrop.active {
    opacity: 1;
    visibility: visible;
  }

  @media (min-width: 768px) {
    .nav-backdrop {
      display: none;
    }
  }

  /* ── Nav links — mobile slide-in, desktop inline ────────────────────────── */
  .nav-links {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100dvh; /* Use dvh for mobile address bar safety */
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 55;
    padding: 2rem;
    border-left: 1px solid rgba(37, 54, 68, 0.08);
  }

  .nav-links.active {
    transform: translateX(0);
  }

  @media (min-width: 768px) {
    .nav-links {
      position: static;
      width: auto;
      height: auto;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      flex-direction: row;
      transform: none;
      gap: 2.5rem;
      padding: 0;
      border-left: none;
    }
  }

  /* ── Nav link ───────────────────────────────────────────────────────────── */
  .nav-link {
    font-family: "Montserrat", sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-vivid-navy);
    opacity: 0.6;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  /* Mobile: larger touch-friendly text */
  @media (max-width: 767px) {
    .nav-link {
      font-size: 0.85rem;
      padding: 0.5rem 1rem;
      opacity: 0.8;
    }
  }

  .nav-link:hover {
    opacity: 1;
  }

  .nav-link:focus-visible {
    opacity: 1;
    outline: 2px solid var(--color-vivid-navy);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* ── Contact CTA — brutalist primary (matches .impeccable.md cards, global buttons) ── */
  .contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.55rem 1.4rem;
    background: var(--color-vivid-navy);
    color: var(--color-vivid-cream);
    border-radius: 0;
    border: 2px solid var(--color-brutalist);
    font-family: "Montserrat", sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    box-shadow: 4px 4px 0 0 var(--color-brutalist);
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      background-color 0.2s ease;
  }

  @media (max-width: 767px) {
    .contact-btn {
      min-height: 48px;
      padding: 0.75rem 2rem;
      font-size: 0.75rem;
    }
  }

  @media (min-width: 768px) {
    .contact-btn {
      padding: 0.65rem 1.6rem;
    }
  }

  .contact-btn:hover {
    background: var(--color-vivid-navy-dark);
    transform: translateY(-2px);
    box-shadow: 8px 8px 0 0 var(--color-brutalist);
  }

  .contact-btn:focus-visible {
    outline: 2px solid var(--color-vivid-teal);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-btn:hover {
      transform: none;
    }
  }

  /* ── Reduced motion ─────────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .nav-container {
      animation: none;
      background: rgba(248, 249, 250, 0.92);
      box-shadow: 0 1px 20px rgba(37, 54, 68, 0.07);
    }

    .nav-links,
    .nav-backdrop,
    .hamburger-line {
      transition-duration: 0.01s !important;
    }
  }
</style>
