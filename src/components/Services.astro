---
import { services } from "../data/home";
---

<section id="services" class="section-tracer-target relative py-24 lg:py-32 bg-vivid-panel overflow-hidden">
  <div class="section-tracer absolute top-0 left-0 w-full h-px bg-vivid-navy origin-left scale-x-0 z-20"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="mb-16">
      <span class="text-vivid-navy font-bold uppercase tracking-[0.4em] text-sm mb-4 inline-block pb-1.5 border-b-[3px] border-vivid-mint">Our Expertise</span>
      <h2
        class="text-6xl md:text-8xl font-black tracking-tighter uppercase text-black leading-[0.85] select-none"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        Serv<span class="text-vivid-mint">ices</span>
      </h2>
    </div>

    <!-- BENTO GRID -->
    <div class="bento-grid">
      {services.map((service) => {
        const Wrapper = service.href ? "a" : "div";
        return (
          <Wrapper href={service.href} class={`bento-tile bento-${service.type} service-card group opacity-0`} id={service.id}>
            <div class="bento-number">{service.number}</div>
            <div class="bento-content">
              <div class="bento-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" set:html={service.iconSVG}></svg>
              </div>
              <h3 class="bento-title">{service.title}</h3>
              <p class="bento-desc">{service.description}</p>
              {service.cta && <span class="bento-cta">{service.cta}</span>}
            </div>
            <div class="bento-bg-glow" style={`background: ${service.glowColor};`}></div>
          </Wrapper>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
  /* Base Bento Grid used in multiple places could be global, but keeping here for now */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }

  @media (max-width: 767px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style>
  /* Match .process-card: transform + shadow ease together (was shadow-only → lift felt snappy vs Process). */
  .bento-tile {
    position: relative;
    overflow: hidden;
    border: 2px solid var(--color-brutalist);
    padding: 2.5rem;
    cursor: pointer;
    transform: translateZ(0);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    text-decoration: none;
  }

  .bento-tile:hover {
    transform: translateY(-4px) translateZ(0);
    box-shadow: 8px 8px 0 0 var(--color-brutalist);
  }

  /* Hero tile spans both rows on left */
  .bento-hero {
    grid-column: 1;
    grid-row: 1 / 3;
    background: var(--color-vivid-navy);
    color: var(--color-white);
    min-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .bento-hero .bento-title { color: var(--color-white); }
  .bento-hero .bento-desc  { color: rgba(255,255,255,0.65); }
  .bento-hero .bento-number { color: rgba(255,255,255,0.08); }
  .bento-hero .bento-icon  { color: var(--color-neon-mint); }

  .bento-secondary {
    grid-column: 2;
    grid-row: 1;
    background: var(--color-vivid-panel);
  }

  .bento-secondary .bento-icon {
    color: var(--color-vivid-navy);
    transition: color 0.35s ease;
  }

  .bento-secondary:hover .bento-icon {
    color: var(--color-neon-mint);
  }

  .bento-accent {
    grid-column: 2;
    grid-row: 2;
    background: var(--color-vivid-cream);
    border-color: var(--color-brutalist);
  }

  .bento-accent .bento-icon {
    color: var(--color-vivid-navy-muted);
    transition: color 0.35s ease;
  }

  .bento-accent:hover .bento-icon {
    color: var(--color-vivid-mint);
  }

  @media (max-width: 767px) {
    .bento-hero, .bento-secondary, .bento-accent {
      grid-column: 1;
      grid-row: auto;
      min-height: 280px;
    }
  }

  .bento-number {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 5rem;
    font-weight: 900;
    color: rgba(0,0,0,0.06);
    line-height: 1;
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    user-select: none;
  }

  .bento-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 1rem;
  }

  .bento-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-vivid-navy);
  }

  .bento-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--color-brutalist);
    line-height: 1.1;
  }

  .bento-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    color: rgba(0,0,0,0.6);
    line-height: 1.6;
    flex: 1;
  }

  .bento-cta {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-neon-mint);
    margin-top: auto;
  }

  .bento-bg-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    filter: blur(80px);
    z-index: 0;
  }

  .bento-tile:hover .bento-bg-glow {
    opacity: 0.08;
  }
</style>
