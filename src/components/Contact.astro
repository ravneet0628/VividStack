---
import Footer from "./Footer.astro";
---

<section id="contact" class="section-tracer-target relative py-20 md:py-40 bg-vivid-navy overflow-hidden">
  <div class="section-tracer absolute top-0 left-0 w-full h-px bg-vivid-mint origin-left scale-x-0 z-20"></div>

  <!-- Ambient Branding Background -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[40rem] font-black text-white/5 select-none leading-none">
      VS
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
    <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 inline-block pb-1.5 border-b-[3px] border-vivid-teal">Ready to scale?</span>
    <h2
      class="text-6xl md:text-8xl font-black tracking-tighter uppercase text-vivid-cream leading-[0.85] select-none mb-16"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      Let's Build <span class="text-vivid-mint">Your</span> Website
    </h2>

    <!-- Brutalist Contact Form -->
    <form id="contact-form" class="w-full max-w-3xl mx-auto flex flex-col gap-6 text-left mb-12 relative z-20">
      <input type="hidden" name="access_key" value="7a57804f-5978-4d98-84e4-0aec35e74482">
      <input type="hidden" name="subject" value="New VividStack Contact Form Submission">
      <input type="hidden" name="from_name" value="VividStack Website">
      <!-- Honeypot: off-screen + removed from a11y tree + no tab stop (Web3Forms botcheck) -->
      <input
        type="checkbox"
        name="botcheck"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        class="sr-only"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col">
          <label for="contact-name" class="text-xs font-bold uppercase tracking-[0.2em] text-vivid-mint mb-2">Name</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            maxlength="200"
            autocomplete="name"
            placeholder="Your Name"
            class="w-full bg-vivid-cream border-2 border-vivid-navy p-4 focus:bg-white focus:outline-none focus:shadow-brutalist-navy-sm focus-visible:ring-2 focus-visible:ring-vivid-teal focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-navy transition-all"
          />
        </div>
        
        <div class="flex flex-col">
          <label for="contact-email" class="text-xs font-bold uppercase tracking-[0.2em] text-vivid-mint mb-2">Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            maxlength="254"
            autocomplete="email"
            placeholder="your.email@example.com"
            class="w-full bg-vivid-cream border-2 border-vivid-navy p-4 focus:bg-white focus:outline-none focus:shadow-brutalist-navy-sm focus-visible:ring-2 focus-visible:ring-vivid-teal focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-navy transition-all"
          />
        </div>
      </div>
      
      <div class="flex flex-col mt-6">
        <label for="contact-message" class="text-xs font-bold uppercase tracking-[0.2em] text-vivid-mint mb-2">Message</label>
        <textarea
          id="contact-message"
          name="message"
          rows="5"
          required
          maxlength="8000"
          autocomplete="off"
          placeholder="Tell us about your business and what you need"
          class="w-full bg-vivid-cream border-2 border-vivid-navy p-4 focus:bg-white focus:outline-none focus:shadow-brutalist-navy-sm focus-visible:ring-2 focus-visible:ring-vivid-teal focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-navy transition-all resize-none"
        ></textarea>
      </div>
      
      <div class="mt-6 flex flex-col md:flex-row items-center justify-between gap-8">
        <!-- hCaptcha widget -->
        <div class="h-captcha" data-captcha="true"></div>
        <button id="submit-btn" type="submit" class="btn-brutalist-secondary">
          Send Message
        </button>
      </div>

      <!-- Success State -->
      <div id="form-success" class="hidden mt-4 p-6 bg-vivid-mint/10 border-2 border-vivid-mint text-center" role="status" aria-live="polite" aria-atomic="true">
        <div class="text-2xl mb-2">✓</div>
        <p class="text-vivid-cream font-bold uppercase tracking-[0.15em] text-sm">Message received!</p>
        <p class="text-vivid-cream/70 text-sm mt-2">We'll get back to you within 24 hours.</p>
      </div>

      <!-- Error State -->
      <div id="form-error" class="hidden mt-4 p-4 bg-red-500/10 border-2 border-red-400 text-center" role="alert" aria-live="assertive" aria-atomic="true">
        <p id="form-error-title" class="text-vivid-cream font-bold uppercase tracking-[0.15em] text-sm">Something went wrong</p>
        <p id="form-error-detail" class="text-vivid-cream/70 text-sm mt-1">Please try again or email us directly.</p>
      </div>
    </form>

    <Footer />
  </div>
</section>

<script>
  // Contact Form Feedback System
  const contactForm = document.getElementById("contact-form");
  const submitBtn = document.getElementById("submit-btn");
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");
  const errorTitleEl = document.getElementById("form-error-title");
  const errorDetailEl = document.getElementById("form-error-detail");

  const defaultErrorTitle = errorTitleEl?.textContent ?? "Something went wrong";
  const defaultErrorDetail = errorDetailEl?.textContent ?? "Please try again or email us directly.";

  if (contactForm && submitBtn) {
    contactForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      
      // Reset states
      successEl?.classList.add("hidden");
      errorEl?.classList.add("hidden");
      if (errorTitleEl) errorTitleEl.textContent = defaultErrorTitle;
      if (errorDetailEl) errorDetailEl.textContent = defaultErrorDetail;

      // Client-side hCaptcha validation (textarea appears after hCaptcha API renders)
      const hCaptchaResponse = contactForm.querySelector('textarea[name="h-captcha-response"]');
      if (hCaptchaResponse && !hCaptchaResponse.value.trim()) {
        errorEl?.classList.remove("hidden");
        if (errorTitleEl) errorTitleEl.textContent = "Verification required";
        if (errorDetailEl) errorDetailEl.textContent = "Complete the captcha below, then send again.";
        return;
      }

      // Button loading state
      const originalText = submitBtn.textContent;
      submitBtn.textContent = "Sending...";
      submitBtn.disabled = true;
      submitBtn.classList.add("is-loading");

      try {
        const formData = new FormData(contactForm);
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: formData,
        });
        const result = await response.json();

        if (result.success) {
          // Show success state
          successEl?.classList.remove("hidden");
          
          // Fade form fields
          const formFields = contactForm.querySelectorAll("input:not([type=hidden]), textarea, .grid, .flex.flex-col.mt-2, .mt-6.flex");
          formFields.forEach(el => {
            el.style.transition = "opacity 0.4s ease";
            el.style.opacity = "0.3";
            el.style.pointerEvents = "none";
          });

          // Update button
          submitBtn.classList.remove("is-loading");
          submitBtn.classList.add("is-success");
          submitBtn.textContent = "✓ Sent";
          
          // Reset form after delay
          setTimeout(() => {
            contactForm.reset();
            formFields.forEach(el => {
              el.style.opacity = "1";
              el.style.pointerEvents = "auto";
            });
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
            submitBtn.classList.remove("is-success");
            successEl?.classList.add("hidden");
          }, 5000);
        } else {
          throw new Error(result.message || "Submission failed");
        }

      } catch (err) {
        errorEl?.classList.remove("hidden");
        if (errorTitleEl) errorTitleEl.textContent = defaultErrorTitle;
        if (errorDetailEl) errorDetailEl.textContent = defaultErrorDetail;
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        submitBtn.classList.remove("is-loading");
      }
    });
  }
</script>
