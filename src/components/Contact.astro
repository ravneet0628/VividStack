<section id="contact" class="section-tracer-target relative py-12 md:py-20 bg-vivid-navy overflow-hidden">
  <div class="section-tracer absolute top-0 left-0 w-full h-px bg-vivid-mint origin-left scale-x-0 z-20"></div>

  <!-- Ambient Branding Background -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[40rem] font-black text-white/5 select-none leading-none">
      VS
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 sm:px-6 relative z-10 text-center">
    <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-2 inline-block pb-1.5 border-b-[3px] border-vivid-teal">Ready to talk?</span>
    <h2
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter uppercase text-vivid-cream leading-[0.88] select-none mb-6 md:mb-8"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      Let's Build <span class="text-vivid-mint">Your</span> Website
    </h2>

    <!-- Brutalist Contact Form -->
    <form
      id="contact-form"
      class="w-full max-w-3xl mx-auto flex flex-col gap-4 text-left mb-6 relative z-20"
      action="https://forms.vividstack.ca/api/forms/vividstack/submissions"
      method="POST"
    >
      <!-- Honeypot: off-screen + removed from a11y tree + no tab stop -->
      <input
        type="checkbox"
        name="botcheck"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        class="sr-only"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="flex flex-col">
          <label for="contact-name" class="text-xs font-bold uppercase tracking-[0.2em] text-vivid-mint mb-2">Name</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            maxlength="200"
            autocomplete="name"
            placeholder="Your Name"
            class="w-full bg-vivid-cream border-2 border-vivid-navy py-3 px-3 md:p-4 focus:bg-white focus:outline-none focus:shadow-brutalist-navy-sm focus-visible:ring-2 focus-visible:ring-vivid-teal focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-navy transition-all"
          />
        </div>
        
        <div class="flex flex-col">
          <label for="contact-email" class="text-xs font-bold uppercase tracking-[0.2em] text-vivid-mint mb-2">Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            maxlength="254"
            autocomplete="email"
            placeholder="your.email@example.com"
            class="w-full bg-vivid-cream border-2 border-vivid-navy py-3 px-3 md:p-4 focus:bg-white focus:outline-none focus:shadow-brutalist-navy-sm focus-visible:ring-2 focus-visible:ring-vivid-teal focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-navy transition-all"
          />
        </div>
      </div>
      
      <div class="flex flex-col mt-3">
        <label for="contact-message" class="text-xs font-bold uppercase tracking-[0.2em] text-vivid-mint mb-2">Message</label>
        <textarea
          id="contact-message"
          name="message"
          rows="3"
          maxlength="8000"
          autocomplete="off"
          placeholder="Tell us about your business and what you need"
          class="w-full bg-vivid-cream border-2 border-vivid-navy py-3 px-3 md:p-4 focus:bg-white focus:outline-none focus:shadow-brutalist-navy-sm focus-visible:ring-2 focus-visible:ring-vivid-teal focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-navy transition-all resize-none"
        ></textarea>
      </div>
      
      <div class="mt-4 flex flex-col md:flex-row items-center justify-between gap-5 md:gap-6">
        <div class="cf-turnstile" data-sitekey="0x4AAAAAAC0usnwAVIEKkaKc"></div>
        <button id="submit-btn" type="submit" class="btn-brutalist-secondary">
          Send Message
        </button>
      </div>

      <!-- Success State -->
      <div
        id="form-success"
        class="form-success-panel hidden mt-4 p-6 bg-vivid-mint/10 border-2 border-vivid-mint text-center"
        role="status"
        aria-live="polite"
        aria-atomic="true"
      >
        <div class="form-success-check text-2xl mb-2 text-vivid-teal font-black" style="font-family: 'Space Grotesk', sans-serif;" aria-hidden="true">✓</div>
        <p class="text-vivid-cream font-bold uppercase tracking-[0.15em] text-sm">Thanks. We got your message.</p>
        <p class="text-vivid-cream/70 text-sm mt-2">We usually reply within one business day.</p>
      </div>

      <!-- Error State -->
      <div
        id="form-error"
        class="form-error-panel hidden mt-4 p-4 bg-red-500/10 border-2 border-red-400 text-center"
        role="alert"
        aria-live="assertive"
        aria-atomic="true"
      >
        <p id="form-error-title" class="text-vivid-cream font-bold uppercase tracking-[0.15em] text-sm">That didn't send</p>
        <p id="form-error-detail" class="text-vivid-cream/70 text-sm mt-1">Try again in a moment, or email us directly. We will still see it.</p>
      </div>
    </form>
  </div>
</section>

<script src="../scripts/contact-form.ts"></script>
