---
import { advantages } from "../data/home";
---

<section id="advantage" class="relative py-24 bg-white overflow-x-clip border-b border-black/5 bg-grid-tech">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="mb-16 text-center">
      <span
        class="text-vivid-navy font-bold uppercase tracking-[0.4em] text-sm mb-4 inline-block pb-1.5 border-b-[3px] border-vivid-mint"
        >Why Choose Us</span
      >
      <h2
        class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-black leading-[0.85]"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        THE VIVID <span class="text-vivid-mint">ADVANTAGE</span>
      </h2>
      <p class="text-vivid-navy/60 font-medium text-lg md:text-xl tracking-tight max-w-2xl mx-auto mt-8">
        Partnership, clear updates, and results you can see, without drowning you in jargon.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-16 pt-6 md:pt-8">
      {advantages.map((item) => {
        const isNavy = item.theme === "navy";
        const isMint = item.theme === "mint";
        const iconBoxClass = isMint
          ? "w-12 h-12 bg-vivid-navy text-vivid-mint flex items-center justify-center mb-6 shadow-brutalist-neon-sm"
          : isNavy
            ? "w-12 h-12 bg-vivid-mint text-vivid-navy flex items-center justify-center mb-6 shadow-brutalist-white-sm"
            : "w-12 h-12 bg-white text-black flex items-center justify-center mb-6 border border-black shadow-brutalist-sm";
        const cardClass = isNavy
          ? "advantage-card group min-w-0 bg-vivid-navy border border-vivid-mint p-8 md:p-10 shadow-brutalist-neon hover:shadow-brutalist-neon-lg opacity-0 transition-[transform,box-shadow] duration-300 ease-out transform hover:-translate-y-1 relative overflow-visible"
          : "advantage-card group min-w-0 bg-vivid-cream border border-black p-8 md:p-10 shadow-brutalist hover:shadow-brutalist-lg opacity-0 transition-[transform,box-shadow] duration-300 ease-out transform hover:-translate-y-1";
        const titleClass = isNavy
          ? "text-xl font-black uppercase tracking-tighter mb-4 leading-tight text-white"
          : "text-xl font-black uppercase tracking-tighter mb-4 leading-tight";
        const descClass = isNavy
          ? "text-white/70 font-medium leading-relaxed break-words"
          : "text-vivid-navy/70 font-medium leading-relaxed break-words";
        return (
          <div class={cardClass}>
            {item.badge && (
              <div class="absolute -top-4 -right-4 bg-white text-vivid-navy font-black text-[10px] px-3 py-1.5 border-2 border-vivid-mint shadow-brutalist-neon-sm z-20 tracking-widest uppercase free-badge">
                {item.badge}
              </div>
            )}
            <div class={iconBoxClass}>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-6 h-6"
                aria-hidden="true"
                set:html={item.iconSVG}
              ></svg>
            </div>
            <h3 class={titleClass} style="font-family: 'Space Grotesk', sans-serif;" set:html={item.title} />
            <p class={descClass} style="font-family: 'Inter', sans-serif;">{item.description}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
