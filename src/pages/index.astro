---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

import Hero from "../components/Hero.astro";
import Advantage from "../components/Advantage.astro";
import Services from "../components/Services.astro";
import SelectedWorks from "../components/SelectedWorks.astro";
import Process from "../components/Process.astro";
import Capabilities from "../components/Capabilities.astro";
import Contact from "../components/Contact.astro";
---

<Layout title="Premium Web Design & Development — Fast, Responsive Websites">
  <Navbar />

  <Hero />
  <Advantage />
  <Services />

  <section
    id="platform"
    class="relative bg-white border-t border-black bg-grid-tech"
  >
    <SelectedWorks />
    <Process />
    <Capabilities />
    <Contact />
  </section>
</Layout>

<script>
  import { initHomeMotion } from "../scripts/home-motion";

  initHomeMotion();
</script>

<style is:global>
  /* ============================================
     NAV
     ============================================ */
  #main-nav {
    z-index: 9999 !important;
  }

  /* ============================================
     SECTION TRACER
     ============================================ */
  .section-tracer {
    will-change: transform;
  }
</style>
