---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro"; 
const portfolioProjects = [
  {
    title: "Vantage Analytics",
    category: "Fintech",
    stack: "Astro + Cloudflare",
    image: "/images/fintech.png",
    accent: "#FFD700" 
  },
  {
    title: "Lumen Architecture",
    category: "Real Estate",
    stack: "React + Tailwind",
    image: "/images/realestate.png",
    accent: "#F5F5DC" 
  },
  {
    title: "Apex Logistics",
    category: "Logistics",
    stack: "Node.js + AWS",
    image: "/images/logistics.png",
    accent: "#666666" 
  },
  {
    title: "Aura Studio",
    category: "Creative Agency",
    stack: "Vite + GSAP",
    image: "/images/agency.png",
    accent: "#006a63" 
  }
];
---

<Layout title="Sophisticated Web Architecture">
  <Navbar /> 
  
  <main class="relative z-0 min-h-screen flex items-center justify-center bg-vivid-cream overflow-hidden text-center px-6">
    
    <div id="ambient-elements" class="absolute inset-0 pointer-events-none z-[-1] opacity-5">
      <div class="absolute top-[8%] left-[5%] w-48 h-48 md:w-64 md:h-64 text-[#253644] -rotate-12">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="2" y1="20" x2="22" y2="20"></line>
        </svg>
      </div>
      <div class="absolute top-[40%] right-[5%] text-[20rem] font-mono leading-none text-[#253644] rotate-12 select-none">
        &#123; &#125;
      </div>
      <div class="absolute bottom-[10%] left-[15%] w-72 h-72 border border-[#253644] rotate-45 flex items-center justify-center">
        <div class="w-full h-[1px] bg-[#253644]"></div>
        <div class="absolute h-full w-[1px] bg-[#253644]"></div>
        <div class="absolute w-2/3 h-2/3 border border-[#253644]"></div>
      </div>
    </div>

    <!-- MacBook Pro Hero Watermark -->
    <div id="hero-laptop" class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 w-[70vw] max-w-[1000px] opacity-10 pointer-events-none z-[-1] mix-blend-multiply will-change-transform">
      <img src="/macbook_hero.png" alt="MacBook Pro" class="w-full h-auto" />
    </div>

    <!-- Ultra-lightweight Digital Structure Nodes -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden mix-blend-multiply">
      <!-- Mint Orb -->
      <div class="absolute -top-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full bg-vivid-mint/[0.04] blur-[120px] animate-pulse" style="animation-duration: 4s;"></div>
      <!-- Core Navy Node -->
      <div class="absolute top-[40%] -left-[15%] w-[50vw] h-[50vw] rounded-full bg-[#253644]/[0.03] blur-[140px]"></div>
      <!-- Center Anchor -->
      <div class="absolute top-[20%] left-[30%] w-[30vw] h-[30vw] rounded-full bg-[#253644]/[0.02] blur-[100px] animate-pulse" style="animation-duration: 6s;"></div>
    </div>

    <!-- Floating Brutalist Tech Nodes -->
    <div class="tech-node absolute top-[25%] left-[5%] md:left-[10%] bg-vivid-cream border border-[#253644] p-4 rounded-none shadow-[4px_4px_0_0_#253644] w-48 text-left hidden md:block opacity-0 translate-y-8">
      <div class="flex items-center gap-2 mb-2 border-b border-[#253644]/20 pb-2">
        <div class="w-3 h-3 rounded-none bg-vivid-mint shadow-[1px_1px_0_0_#253644]"></div>
        <span class="text-[0.6rem] font-bold uppercase tracking-[0.2em] text-[#253644]">Status</span>
      </div>
      <div class="text-[#253644] font-mono text-xs font-bold tracking-tight">SYS_NOMINAL</div>
    </div>

    <div class="tech-node absolute bottom-[15%] right-[5%] md:right-[10%] bg-[#253644] border border-[#253644] p-5 rounded-none shadow-[6px_6px_0_0_#006a63] w-56 text-left hidden md:block opacity-0 translate-y-8">
      <div class="flex justify-between items-center mb-3">
        <div class="text-[0.65rem] font-bold uppercase tracking-widest text-[#f3f3f4]/70">Latency</div>
        <div class="text-vivid-mint font-mono text-sm font-bold">12ms</div>
      </div>
      <div class="w-full bg-[#f3f3f4]/10 h-2 rounded-none overflow-hidden border border-[#f3f3f4]/20">
        <div class="w-[20%] bg-vivid-mint h-full shadow-[1px_0_0_#000000]"></div>
      </div>
    </div>

    <div class="tech-node absolute top-[15%] right-[15%] lg:right-[20%] bg-[#f3f3f4] backdrop-blur-sm border border-[#253644] p-3 rounded-none shadow-[3px_3px_0_0_#253644] hidden lg:flex items-center gap-3 opacity-0 translate-y-8">
      <div class="w-8 h-8 flex items-center justify-center bg-[#253644] text-vivid-mint font-mono text-sm font-bold shadow-[2px_2px_0_0_#006a63]">
        99
      </div>
      <span class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-[#253644] pr-3">Perf</span>
    </div>

    <div class="z-10 w-full max-w-7xl mx-auto flex flex-col items-center">
      <div id="hero-brand" class="mb-4" style="perspective: 1000px;">
        <h1 class="text-6xl sm:text-8xl md:text-[7rem] lg:text-[9rem] font-extrabold tracking-tighter uppercase leading-none drop-shadow-sm flex flex-wrap justify-center gap-x-[2vw]">
          <span class="text-[#253644] flex">
            {"Vivid".split("").map((char) => <span class="hero-char inline-block will-change-transform">{char}</span>)}
          </span>
          <span class="text-[#95cbd0] flex">
            {"Stack".split("").map((char) => <span class="hero-char inline-block will-change-transform">{char}</span>)}
          </span>
        </h1>
      </div>
      <h2 id="hero-title" class="text-lg sm:text-xl md:text-2xl font-bold tracking-[0.2em] text-[#253644] uppercase opacity-0 translate-y-12 mt-2">
        UNCOMPROMISING DIGITAL <span class="text-[#95cbd0]">ARCHITECTURE.</span>
      </h2>
      
      <p id="hero-subtitle" class="mt-8 md:mt-10 text-xl md:text-2xl lg:text-3xl text-vivid-navy/70 font-medium tracking-wide opacity-0 translate-y-8 max-w-3xl">
        High-performance web systems for ambitious businesses.
      </p>

      <div id="hero-cta" class="mt-12 md:mt-16 opacity-0 translate-y-8">
        <a href="#tools" class="group relative inline-flex items-center gap-3 px-10 py-5 bg-vivid-navy text-vivid-cream rounded-full overflow-hidden transition-all hover:pr-14 hover:scale-105 duration-300 shadow-[0_10px_30px_rgba(37,54,68,0.2)]">
          <span class="relative z-10 font-bold uppercase tracking-widest text-sm md:text-base">Explore the Stack</span>
          <div class="absolute right-5 translate-x-10 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 font-bold text-lg text-vivid-mint">
            →
          </div>
        </a>
      </div>
    </div>
  </main>

  <section id="services" class="section-tracer-target relative pt-16 pb-32 lg:pt-24 bg-white overflow-hidden">
    <div class="section-tracer absolute top-0 left-0 w-full h-px bg-[#000000] origin-left scale-x-0 z-20 will-change-transform"></div>


    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="mb-20 text-center">
        <span class="text-[#006a63] font-bold uppercase tracking-[0.2em] text-sm md:text-base">Our Expertise</span>
        <h2 class="text-5xl md:text-7xl font-bold mt-4 tracking-tighter uppercase text-[#000000]" style="font-family: 'Space Grotesk', sans-serif;">Services</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 md:gap-12">
        <div class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px]">
          <div>
            <div class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif;">01</div>
            <h3 class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif;">Scalable Architecture</h3>
            <p class="text-[#000000]/70 leading-relaxed font-medium" style="font-family: 'Inter', sans-serif;">
              High-performance engineering using modern frameworks to build robust systems designed for speed.
            </p>
          </div>
        </div>

        <div class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px]">
          <div>
            <div class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif;">02</div>
            <h3 class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif;">Custom Business Logic</h3>
            <p class="text-[#000000]/70 leading-relaxed font-medium" style="font-family: 'Inter', sans-serif;">
              Tailored digital workflows and backend systems perfectly aligned with your enterprise operational needs.
            </p>
          </div>
        </div>

        <div class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px]">
          <div>
            <div class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif;">03</div>
            <h3 class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif;">Brand Performance</h3>
            <p class="text-[#000000]/70 leading-relaxed font-medium" style="font-family: 'Inter', sans-serif;">
              Optimized digital experiences that maximize conversion rates while maintaining rigorous aesthetic standards.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>  <section id="selected-works" class="relative bg-white border-t border-black bg-grid-tech">
    <div class="pin-wrap flex gap-32 px-[15vw] items-center h-screen will-change-transform">
      
      <!-- Section Title Card -->
      <div class="flex-shrink-0 w-[40vw] flex items-center justify-start relative will-change-transform">
        <div class="relative">
          <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block">Case Studies</span>
          <h2 class="text-8xl md:text-9xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none" style="font-family: 'Space Grotesk', sans-serif;">
            SELECTED<br/>WORK
          </h2>
          <div class="mt-8 w-24 h-1 bg-black"></div>
        </div>
      </div>
      
      <!-- Project Card 1: Reset at 30 -->
      <div class="project-card flex-shrink-0 w-[55vw] h-[80vh] flex items-center justify-center relative will-change-transform">
        <!-- Ambient Glow -->
        <div class="absolute inset-0 flex items-center justify-center -z-10">
          <div class="w-[60%] h-[60%] bg-[#00ffcc]/10 blur-[100px] rounded-full"></div>
        </div>
        
        <div class="relative w-full max-w-5xl">
          <div class="browser-window bg-white border border-black relative z-10 shadow-[20px_20px_0_0_#000000] overflow-hidden">
            <div class="h-8 bg-[#f3f3f4] border-b border-black flex items-center px-4 gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="flex-grow text-[10px] text-black/40 font-mono text-center truncate uppercase tracking-widest pl-4">resetat30.com // active</div>
            </div>
            <div class="aspect-[16/10] bg-white relative overflow-hidden">
              <img src="/resetat30.png" alt="Reset at 30" class="w-full h-auto" loading="lazy" />
            </div>
          </div>
          
          <!-- Technical Metadata -->
          <div class="mt-8 flex items-center justify-between border-b border-black/10 pb-4">
            <div class="flex gap-4">
              <span class="text-[10px] font-bold uppercase tracking-widest text-black" style="font-family: 'Inter', sans-serif;">Astro v4.0</span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-black/40" style="font-family: 'Inter', sans-serif;">Cloudflare Edge</span>
            </div>
            <span class="text-[10px] font-mono text-black/20 uppercase">Core_System_01</span>
          </div>

          <!-- Mobile Mockup -->
          <div class="mobile-mockup absolute -bottom-16 -right-12 w-1/4 max-w-[200px] z-20 border border-black bg-white shadow-[12px_12px_0_0_#000000] will-change-transform">
             <div class="p-2 bg-[#f3f3f4] border-b border-black h-4 flex items-center justify-center">
                 <div class="w-8 h-1 bg-black/20 rounded-full"></div>
             </div>
             <div class="aspect-[9/19.5] overflow-hidden">
                <img src="/resetat30.png" alt="Mobile View" class="w-full h-full object-cover grayscale brightness-110" loading="lazy" />
             </div>
          </div>
        </div>
      </div>

      <!-- Project Card 2: HM Global -->
      <div class="project-card flex-shrink-0 w-[55vw] h-[80vh] flex items-center justify-center relative will-change-transform">
        <!-- Ambient Glow -->
        <div class="absolute inset-0 flex items-center justify-center -z-10">
          <div class="w-[60%] h-[60%] bg-[#0066ff]/10 blur-[100px] rounded-full"></div>
        </div>

        <div class="relative w-full max-w-5xl">
          <div class="browser-window bg-white border border-black relative z-10 shadow-[20px_20px_0_0_#000000] overflow-hidden">
            <div class="h-8 bg-[#f3f3f4] border-b border-black flex items-center px-4 gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="flex-grow text-[10px] text-black/40 font-mono text-center truncate uppercase tracking-widest pl-4">hmglobalinc.com // node_cluster</div>
            </div>
            <div class="aspect-[16/10] bg-white relative overflow-hidden">
              <img src="/hmglobal.png" alt="HM Global Inc" class="w-full h-auto" loading="lazy" />
            </div>
          </div>

          <!-- Technical Metadata -->
          <div class="mt-8 flex items-center justify-between border-b border-black/10 pb-4">
            <div class="flex gap-4">
              <span class="text-[10px] font-bold uppercase tracking-widest text-black" style="font-family: 'Inter', sans-serif;">Enterprise Stack</span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-black/40" style="font-family: 'Inter', sans-serif;">Scalable Infrastructure</span>
            </div>
            <span class="text-[10px] font-mono text-black/20 uppercase">Core_System_02</span>
          </div>

          <div class="mobile-mockup absolute -bottom-16 -right-12 w-1/4 max-w-[200px] z-20 border border-black bg-white shadow-[12px_12px_0_0_#000000] will-change-transform">
             <div class="p-2 bg-[#f3f3f4] border-b border-black h-4 flex items-center justify-center">
                 <div class="w-8 h-1 bg-black/20 rounded-full"></div>
             </div>
             <div class="aspect-[9/19.5] overflow-hidden">
                <img src="/hmglobal.png" alt="Mobile View" class="w-full h-full object-cover grayscale brightness-110" loading="lazy" />
             </div>
          </div>
        </div>
      </div>

      <!-- Project Card 3: SecureChoice -->
      <div class="project-card flex-shrink-0 w-[55vw] h-[80vh] flex items-center justify-center relative will-change-transform">
        <!-- Ambient Glow -->
        <div class="absolute inset-0 flex items-center justify-center -z-10">
          <div class="w-[60%] h-[60%] bg-[#9900ff]/10 blur-[100px] rounded-full"></div>
        </div>

        <div class="relative w-full max-w-5xl">
          <div class="browser-window bg-white border border-black relative z-10 shadow-[20px_20px_0_0_#000000] overflow-hidden">
            <div class="h-8 bg-[#f3f3f4] border-b border-black flex items-center px-4 gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="flex-grow text-[10px] text-black/40 font-mono text-center truncate uppercase tracking-widest pl-4">top-insurance.pages.dev // encrypted</div>
            </div>
            <div class="aspect-[16/10] bg-white relative overflow-hidden">
              <img src="/securechoice.png" alt="SecureChoice Insurance" class="w-full h-auto" loading="lazy" />
            </div>
          </div>

          <!-- Technical Metadata -->
          <div class="mt-8 flex items-center justify-between border-b border-black/10 pb-4">
            <div class="flex gap-4">
              <span class="text-[10px] font-bold uppercase tracking-widest text-black" style="font-family: 'Inter', sans-serif;">Risk Architecture</span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-black/40" style="font-family: 'Inter', sans-serif;">Security Protocol</span>
            </div>
            <span class="text-[10px] font-mono text-black/20 uppercase">Core_System_03</span>
          </div>

          <div class="mobile-mockup absolute -bottom-16 -right-12 w-1/4 max-w-[200px] z-20 border border-black bg-white shadow-[12px_12px_0_0_#000000] will-change-transform">
             <div class="p-2 bg-[#f3f3f4] border-b border-black h-4 flex items-center justify-center">
                 <div class="w-8 h-1 bg-black/20 rounded-full"></div>
             </div>
             <div class="aspect-[9/19.5] overflow-hidden">
                <img src="/securechoice.png" alt="Mobile View" class="w-full h-full object-cover grayscale brightness-110" loading="lazy" />
             </div>
          </div>
        </div>
      </div>

      <!-- Project Card 4: PhotoLP -->
      <div class="project-card flex-shrink-0 w-[55vw] h-[80vh] flex items-center justify-center relative will-change-transform">
        <!-- Ambient Glow -->
        <div class="absolute inset-0 flex items-center justify-center -z-10">
          <div class="w-[60%] h-[60%] bg-[#ff9900]/10 blur-[100px] rounded-full"></div>
        </div>

        <div class="relative w-full max-w-5xl">
          <div class="browser-window bg-white border border-black relative z-10 shadow-[20px_20px_0_0_#000000] overflow-hidden">
            <div class="h-8 bg-[#f3f3f4] border-b border-black flex items-center px-4 gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
              <div class="flex-grow text-[10px] text-black/40 font-mono text-center truncate uppercase tracking-widest pl-4">shivstudio.onrender.com // asset_node</div>
            </div>
            <div class="aspect-[16/10] bg-white relative overflow-hidden">
              <img src="/photolp.png" alt="PhotoLP Portfolio" class="w-full h-auto" loading="lazy" />
            </div>
          </div>

          <!-- Technical Metadata -->
          <div class="mt-8 flex items-center justify-between border-b border-black/10 pb-4">
            <div class="flex gap-4">
              <span class="text-[10px] font-bold uppercase tracking-widest text-black" style="font-family: 'Inter', sans-serif;">Creative Delivery</span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-black/40" style="font-family: 'Inter', sans-serif;">React + Vite</span>
            </div>
            <span class="text-[10px] font-mono text-black/20 uppercase">Core_System_04</span>
          </div>

          <div class="mobile-mockup absolute -bottom-16 -right-12 w-1/4 max-w-[200px] z-20 border border-black bg-white shadow-[12px_12px_0_0_#000000] will-change-transform">
             <div class="p-2 bg-[#f3f3f4] border-b border-black h-4 flex items-center justify-center">
                 <div class="w-8 h-1 bg-black/20 rounded-full"></div>
             </div>
             <div class="aspect-[9/19.5] overflow-hidden">
                <img src="/photolp.png" alt="Mobile View" class="w-full h-full object-cover grayscale brightness-110" loading="lazy" />
             </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section id="process" class="section-tracer-target relative py-32 bg-[#f3f3f4] overflow-hidden">
    <div class="section-tracer absolute top-0 left-0 w-full h-px bg-[#000000] origin-left scale-x-0 z-20 will-change-transform"></div>


    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="mb-24 md:mb-32">
        <span class="text-[#006a63] font-bold uppercase tracking-[0.2em] text-sm md:text-base">How We Work</span>
        <h2 class="text-5xl md:text-7xl font-extrabold mt-4 tracking-tighter uppercase text-[#000000]" style="font-family: 'Space Grotesk', sans-serif;">The Process</h2>
      </div>

      <div class="flex flex-col border-t border-[#000000]">
        
        <!-- Phase 1 -->
        <div class="process-row grid grid-cols-1 md:grid-cols-12 border-b border-[#000000] bg-white transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]">
          <div class="p-8 md:p-12 md:col-span-5 flex flex-col md:flex-row items-start md:items-center border-b md:border-b-0 border-[#000000]">
            <h3 class="phase-title text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-[#000000] tracking-tighter transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif; font-weight: 800;">
              01 DISCOVERY
            </h3>
          </div>
          <div class="p-8 md:p-12 md:col-span-7 flex items-center justify-start md:justify-end text-left md:text-right border-l-0 md:border-l border-[#000000]">
            <p class="text-base md:text-lg text-[#000000]/80 leading-relaxed font-normal max-w-lg" style="font-family: 'Inter', sans-serif;">
              We dive deep into your business goals, target audience, and brand soul to map out a strategic digital blueprint before writing a single line of code.
            </p>
          </div>
        </div>

        <!-- Phase 2 -->
        <div class="process-row grid grid-cols-1 md:grid-cols-12 border-b border-[#000000] bg-[#f8f9fa] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]">
          <div class="p-8 md:p-12 md:col-span-5 flex flex-col md:flex-row items-start md:items-center border-b md:border-b-0 border-[#000000]">
            <h3 class="phase-title text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-[#000000] tracking-tighter transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif; font-weight: 800;">
              02 ARCHITECTURE
            </h3>
          </div>
          <div class="p-8 md:p-12 md:col-span-7 flex items-center justify-start md:justify-end text-left md:text-right border-l-0 md:border-l border-[#000000]">
            <p class="text-base md:text-lg text-[#000000]/80 leading-relaxed font-normal max-w-lg" style="font-family: 'Inter', sans-serif;">
              Where sophisticated tech meets uncompromising aesthetics. We craft a rigid visual identity and data schema that commands total authority.
            </p>
          </div>
        </div>

        <!-- Phase 3 -->
        <div class="process-row grid grid-cols-1 md:grid-cols-12 border-b border-[#000000] bg-white transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]">
          <div class="p-8 md:p-12 md:col-span-5 flex flex-col md:flex-row items-start md:items-center border-b md:border-b-0 border-[#000000]">
            <h3 class="phase-title text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-[#000000] tracking-tighter transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]" style="font-family: 'Space Grotesk', sans-serif; font-weight: 800;">
              03 DEPLOYMENT
            </h3>
          </div>
          <div class="p-8 md:p-12 md:col-span-7 flex items-center justify-start md:justify-end text-left md:text-right border-l-0 md:border-l border-[#000000]">
            <p class="text-base md:text-lg text-[#000000]/80 leading-relaxed font-normal max-w-lg" style="font-family: 'Inter', sans-serif;">
              Using the modern stack, we launch a high-performance engine that is fast, secure, and infinitely scalable across global edge networks.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section id="portfolio" class="section-tracer-target relative py-32 bg-vivid-cream bg-grid-tech">
    <div class="section-tracer absolute top-0 left-0 w-full h-px bg-vivid-navy origin-left scale-x-0 z-20 will-change-transform"></div>
    
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="mb-24 text-center">
        <span class="text-vivid-mint font-bold uppercase tracking-[0.3em] text-sm md:text-base mb-4 block" style="font-family: 'Inter', sans-serif;">Featured Work</span>
        <h2 class="text-6xl md:text-8xl font-black tracking-tighter uppercase text-vivid-navy" style="font-family: 'Space Grotesk', sans-serif;">Portfolio</h2>
      </div>

      <div class="portfolio-grid grid grid-cols-1 md:grid-cols-2 gap-12">
        {portfolioProjects.map((project, index) => (
          <div class="portfolio-item group relative bg-white border border-vivid-navy/10 transition-all duration-300 hover:border-vivid-mint opacity-0 translate-y-8 flex flex-col h-full shadow-[0_10px_30px_rgba(37,54,68,0.04)]">
            <div class="relative overflow-hidden aspect-[16/10]">
              <img 
                src={project.image} 
                alt={project.title} 
                class="w-full h-full object-cover transition-all duration-700 ease-architectural scale-100 group-hover:scale-105" 
                loading="lazy"
              />
              <div class="absolute inset-0 bg-vivid-navy/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>
            
            <div class="p-8 md:p-12 border-t border-vivid-navy/5 flex flex-col justify-between flex-grow">
              <div>
                <div class="flex items-center gap-3 mb-6">
                  <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-vivid-navy text-white font-sans">{project.category}</span>
                  <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-vivid-navy/40" style="font-family: 'Inter', sans-serif;">{project.stack}</span>
                </div>
                <h3 class="text-3xl md:text-5xl font-extrabold uppercase tracking-tight text-vivid-navy leading-none" style="font-family: 'Space Grotesk', sans-serif;">{project.title}</h3>
              </div>
              
              <div class="mt-12 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-px bg-vivid-navy group-hover:w-20 group-hover:bg-vivid-mint transition-all duration-500"></div>
                  <span class="text-[10px] font-bold uppercase tracking-widest text-vivid-navy group-hover:text-vivid-mint transition-colors duration-500">Case Study</span>
                </div>
                <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-vivid-mint font-bold translate-x-[-10px] group-hover:translate-x-0">→</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>



<script>
  import Lenis from "lenis";
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { CustomEase } from "gsap/CustomEase";

  gsap.registerPlugin(ScrollTrigger, CustomEase);
  
  // Register the precise architectural cubic-bezier
  CustomEase.create("architectural", "0.4, 0, 0.2, 1");

  // Initialize Lenis with tuned cinematic smoothing
  const lenis = new Lenis({
    lerp: 0.1,
    wheelMultiplier: 1,
    smoothWheel: true,
  });

  // Sync GSAP ScrollTrigger with Lenis
  lenis.on('scroll', ScrollTrigger.update);

  // Use requestAnimationFrame for Lenis to ensure instant input response
  function raf(time) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  gsap.ticker.lagSmoothing(0);

  const tl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1.4, force3D: true } });
  
  // Explicitly apply will-change to elements before animation starts to hardware accelerate them
  gsap.set(["#main-nav", ".hero-char", "#hero-title", "#hero-subtitle", "#hero-cta", ".service-card", "#selected-works", ".project-screenshot", ".tech-node", "#ambient-elements > div"], { willChange: "transform, opacity" });

  tl.to("#main-nav", { opacity: 1, y: 0, delay: 0.2 })
    .from(".hero-char", {
      rotationX: 90,
      opacity: 0,
      y: 20,
      stagger: 0.05,
      duration: 1.0,
      ease: "power3.out",
      transformOrigin: "center bottom"
    }, "-=1.1")
    .to("#hero-title", { opacity: 1, y: 0 }, "-=0.8") 
    .to("#hero-subtitle", { opacity: 1, y: 0 }, "-=1.1")
    .to("#hero-cta", { opacity: 1, y: 0 }, "-=1.1")
    .to(".tech-node", { opacity: 1, y: 0, stagger: 0.1 }, "-=1.0");

  // Floating animation for ambient tech elements
  gsap.utils.toArray("#ambient-elements > div").forEach((element) => {
    gsap.to(element, {
      x: "random(-20, 20)",
      y: "random(-20, 20)",
      duration: "random(6, 10)",
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      force3D: true,
    });
  });

  // Floating orbit animation loop for tech nodes
  gsap.utils.toArray(".tech-node").forEach((node, i) => {
    gsap.to(node, {
      y: (i % 2 === 0 ? 15 : -15), // Alternate direction
      rotation: (i % 2 === 0 ? 1 : -1),
      duration: 2.5 + (i * 0.5),
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      force3D: true,
      delay: i * 0.2
    });
  });

  // Services Slide Animations
  gsap.to(".service-card", {
    scrollTrigger: { trigger: "#services", start: "top 80%" },
    opacity: 1, 
    y: 0, 
    duration: 1.2, 
    stagger: 0.2, 
    ease: "power2.out", 
    force3D: true
  });

  // Horizontal Scroll with Pinning for Selected Works
  const worksSection = document.querySelector("#selected-works");
  const pinWrap = document.querySelector(".pin-wrap");
  
  if (worksSection && pinWrap) {
    const totalWidth = pinWrap.scrollWidth;
    const viewportWidth = window.innerWidth;
    
    const worksTl = gsap.timeline({
      scrollTrigger: {
        trigger: worksSection,
        start: "top top",
        end: "+=300%",
        pin: true,
        scrub: 1,
        anticipatePin: 1,
        invalidateOnRefresh: true,
      }
    });

    worksTl.to(pinWrap, {
      x: -(totalWidth - viewportWidth),
      ease: "none",
    });

    // Sub-animation: 1.2x Parallax for Mobile Devices
    // Since mockups are inside cards, we animate them relative to their parent
    // To achieve 1.2x, we give them an extra offset in the same direction
    gsap.utils.toArray(".mobile-mockup").forEach((mockup) => {
      worksTl.to(mockup, {
        x: -120, // Precise 1.2x feel glide
        ease: "none",
      }, 0);
    });
  }

  // Magnetic Hero Headline Letters
  const heroChars = gsap.utils.toArray(".hero-char");
  
  if (heroChars.length > 0) {
    window.addEventListener("mousemove", (e) => {
      const mouseX = e.clientX;
      const mouseY = e.clientY;

      heroChars.forEach((char) => {
        const rect = char.getBoundingClientRect();
        const charX = rect.left + rect.width / 2;
        const charY = rect.top + rect.height / 2;

        const distX = mouseX - charX;
        const distY = mouseY - charY;
        const distance = Math.sqrt(distX * distX + distY * distY);

        const magnetRadius = 100; // Activation distance in pixels

        if (distance < magnetRadius) {
          // Calculate pull fraction (closer = stronger pull)
          const pull = 1 - (distance / magnetRadius);
          
          // Max displacement is 10px
          const moveX = (distX / distance) * pull * 10;
          const moveY = (distY / distance) * pull * 10;

          gsap.to(char, {
            x: moveX,
            y: moveY,
            rotationY: moveX * 0.5, // Subtle 3D leaning
            rotationX: -moveY * 0.5,
            duration: 0.3,
            ease: "power2.out",
            overwrite: "auto"
          });
        } else {
          // Reset when out of range
          gsap.to(char, {
            x: 0,
            y: 0,
            rotationY: 0,
            rotationX: 0,
            duration: 0.6,
            ease: "power3.out",
            overwrite: "auto"
          });
        }
      });
    });
  }

  // Section Tracer Border Animation
  gsap.utils.toArray(".section-tracer-target").forEach((section) => {
    const tracer = section.querySelector(".section-tracer");
    if (tracer) {
      gsap.to(tracer, {
        scaleX: 1,
        duration: 1.2,
        ease: "power3.inOut",
        force3D: true,
        scrollTrigger: {
          trigger: section,
          start: "top 85%", // Triggers precisely as the section enters the bottom viewport mask
          toggleActions: "play none none reverse"
        }
      });
    }
  });

  // MacBook Hero Float and Parallax
  const heroLaptop = document.querySelector("#hero-laptop");
  if (heroLaptop) {
    // Ambient floating
    gsap.to(heroLaptop, {
      y: "+=20",
      rotation: 1,
      duration: 4,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      force3D: true
    });

    // Scroll parallax "fall" behind text
    gsap.to(heroLaptop, {
      y: "30vh", 
      opacity: 0.05,
      scrollTrigger: {
        trigger: "main",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });
  }

  // Portfolio Staggered Rise Animation
  const portfolioItems = gsap.utils.toArray(".portfolio-item");
  if (portfolioItems.length > 0) {
    gsap.to(portfolioItems, {
      y: 0,
      opacity: 1,
      duration: 1.2,
      stagger: 0.15,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ".portfolio-grid",
        start: "top 80%",
        toggleActions: "play none none reverse"
      }
    });
  }
</script>
