---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
const portfolioProjects = [
  {
    title: "Reset at 30",
    category: "Core_System_01",
    stack: "Astro + Cloudflare Edge",
    image: "/resetat30.png",
    accent: "#00ffcc",
  },
  {
    title: "HM Global",
    category: "Industrial Node",
    stack: "Enterprise Architecture",
    image: "/images/hmglobal.png",
    accent: "#0066ff",
  },
  {
    title: "Secure Choice",
    category: "Secure API",
    stack: "Risk Architecture",
    image: "/securechoice.png",
    accent: "#9900ff",
  },
  {
    title: "PhotoLP",
    category: "Asset Node",
    stack: "React + Vite + Render",
    image: "/photolp.png",
    accent: "#ff9900",
  },
];
---

<Layout title="Sophisticated Web Architecture">
  <Navbar />

  <main
    class="relative z-0 min-h-screen flex items-center justify-center bg-vivid-cream overflow-hidden text-center px-6"
  >
    <div
      id="ambient-elements"
      class="absolute inset-0 pointer-events-none z-[-1] opacity-5"
    >
      <div
        class="absolute top-[8%] left-[5%] w-48 h-48 md:w-64 md:h-64 text-[#253644] -rotate-12"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="0.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-full h-full"
        >
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="2" y1="20" x2="22" y2="20"></line>
        </svg>
      </div>
      <div
        class="absolute top-[35%] right-[2%] text-[24rem] font-mono leading-none text-[#253644] rotate-[-15deg] select-none opacity-5"
      >
        &#123;
      </div>
      <div
        class="absolute bottom-[20%] right-[15%] text-[24rem] font-mono leading-none text-[#253644] rotate-[15deg] select-none opacity-5"
      >
        &#125;
      </div>
      <div
        class="absolute bottom-[10%] left-[15%] w-72 h-72 border border-[#253644] rotate-45 flex items-center justify-center"
      >
        <div class="w-full h-[1px] bg-[#253644]"></div>
        <div class="absolute h-full w-[1px] bg-[#253644]"></div>
        <div class="absolute w-2/3 h-2/3 border border-[#253644]"></div>
      </div>
    </div>

    <!-- Hero Code Structure Watermark -->
    <div
      id="hero-background"
      class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 w-[85vw] max-w-[1200px] opacity-[0.03] pointer-events-none z-[-1] transition-opacity duration-1000"
    >
      <img
        src="/hero_code.png"
        alt="Code Architecture"
        class="w-full h-auto grayscale"
      />
    </div>

    <!-- Ultra-lightweight Digital Structure Nodes -->
    <div
      class="absolute inset-0 pointer-events-none overflow-hidden mix-blend-multiply"
    >
      <!-- Mint Orb -->
      <div
        class="absolute -top-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full bg-vivid-mint/[0.04] blur-[120px] animate-pulse"
        style="animation-duration: 4s;"
      >
      </div>
      <!-- Core Navy Node -->
      <div
        class="absolute top-[40%] -left-[15%] w-[50vw] h-[50vw] rounded-full bg-[#253644]/[0.03] blur-[140px]"
      >
      </div>
      <!-- Center Anchor -->
      <div
        class="absolute top-[20%] left-[30%] w-[30vw] h-[30vw] rounded-full bg-[#253644]/[0.02] blur-[100px] animate-pulse"
        style="animation-duration: 6s;"
      >
      </div>
    </div>

    <!-- Floating Brutalist Tech Nodes -->
    <div
      class="tech-node absolute top-[45%] left-[6%] md:left-[8%] bg-white/95 backdrop-blur-sm border border-[#253644] p-5 rounded-none shadow-[10px_10px_0_0_#253644] w-52 text-left hidden md:block opacity-0 translate-y-8"
    >
      <div
        class="flex items-center gap-3 mb-2 border-b border-[#253644]/10 pb-3"
      >
        <div
          class="w-3 h-3 rounded-none bg-[#95cbd0] shadow-[1px_1px_0_0_#253644]"
        >
        </div>
        <span
          class="text-[0.65rem] font-bold uppercase tracking-[0.25em] text-[#253644]"
          >Health_State</span
        >
      </div>
      <div class="text-[#253644] font-mono text-sm font-bold tracking-tight">
        SYS_NOMINAL
      </div>
    </div>

    <div
      class="tech-node absolute bottom-[22%] right-[10%] md:right-[12%] bg-[#253644] border border-[#253644] p-6 rounded-none shadow-[12px_12px_0_0_#95cbd0] w-64 text-left hidden md:block opacity-0 translate-y-8"
    >
      <div class="flex justify-between items-center mb-4">
        <div
          class="text-[0.65rem] font-bold uppercase tracking-widest text-white/50"
        >
          Edge Latency
        </div>
        <div class="text-[#95cbd0] font-mono text-sm font-bold">12ms</div>
      </div>
      <div
        class="w-full bg-white/5 h-2 rounded-none overflow-hidden border border-white/10"
      >
        <div class="w-[20%] bg-[#95cbd0] h-full shadow-[1px_0_0_#000000]"></div>
      </div>
    </div>

    <div
      class="tech-node absolute top-[18%] right-[4%] lg:right-[5%] bg-white backdrop-blur-md border border-[#253644] p-4 rounded-none shadow-[8px_8px_0_0_#253644] hidden lg:flex items-center gap-5 opacity-0 translate-y-8"
    >
      <div
        class="w-10 h-10 flex items-center justify-center bg-[#253644] text-[#95cbd0] font-mono text-base font-bold shadow-[3px_3px_0_0_#95cbd0]"
      >
        99
      </div>
      <div class="flex flex-col">
        <span
          class="text-[0.65rem] font-bold uppercase tracking-[0.3em] text-[#253644]"
          >Architecture</span
        >
        <span
          class="text-[0.6rem] font-bold uppercase tracking-[0.2em] text-[#253644]/40"
          >Score_P76</span
        >
      </div>
    </div>

    <div class="z-10 w-full max-w-7xl mx-auto flex flex-col items-center">
      <div id="hero-brand" class="mb-4" style="perspective: 1000px;">
        <h1
          class="text-6xl sm:text-8xl md:text-[7rem] lg:text-[9rem] font-extrabold tracking-tighter uppercase leading-none drop-shadow-sm flex flex-wrap justify-center gap-x-[2vw]"
        >
          <span class="text-[#253644] flex">
            {
              "Vivid"
                .split("")
                .map((char) => (
                  <span class="hero-char inline-block will-change-transform">
                    {char}
                  </span>
                ))
            }
          </span>
          <span class="text-[#95cbd0] flex">
            {
              "Stack"
                .split("")
                .map((char) => (
                  <span class="hero-char inline-block will-change-transform">
                    {char}
                  </span>
                ))
            }
          </span>
        </h1>
      </div>
      <h2
        id="hero-title"
        class="text-lg sm:text-xl md:text-2xl font-bold tracking-[0.2em] text-[#253644] uppercase opacity-0 translate-y-12 mt-2"
      >
        UNCOMPROMISING DIGITAL <span class="text-[#95cbd0]">ARCHITECTURE.</span>
      </h2>

      <p
        id="hero-subtitle"
        class="mt-8 md:mt-10 text-xl md:text-2xl lg:text-3xl text-vivid-navy/70 font-medium tracking-wide opacity-0 translate-y-8 max-w-3xl"
      >
        High-performance web systems for ambitious businesses.
      </p>

      <div id="hero-cta" class="mt-12 md:mt-16 opacity-0 translate-y-8">
        <a
          href="#portfolio"
          class="group relative inline-flex items-center gap-3 px-10 py-5 bg-vivid-navy text-vivid-cream rounded-full overflow-hidden transition-all hover:pr-14 hover:scale-105 duration-300 shadow-[0_10px_30px_rgba(37,54,68,0.2)]"
        >
          <span
            class="relative z-10 font-bold uppercase tracking-widest text-sm md:text-base"
            >Explore the Stack</span
          >
          <div
            class="absolute right-5 translate-x-10 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 font-bold text-lg text-vivid-mint"
          >
            →
          </div>
        </a>
      </div>
    </div>
  </main>

  <section
    id="services"
    class="section-tracer-target relative pt-16 pb-32 lg:pt-24 bg-white overflow-hidden"
  >
    <div
      class="section-tracer absolute top-0 left-0 w-full h-px bg-[#000000] origin-left scale-x-0 z-20 will-change-transform"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="mb-20 text-center">
        <span
          class="text-[#006a63] font-bold uppercase tracking-[0.2em] text-sm md:text-base"
          >Our Expertise</span
        >
        <h2
          class="text-5xl md:text-7xl font-bold mt-4 tracking-tighter uppercase text-[#000000]"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          Services
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 md:gap-12">
        <a
          href="#portfolio"
          class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px] cursor-pointer block"
        >
          <div>
            <div
              class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              01
            </div>
            <h3
              class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              Scalable Architecture
            </h3>
            <p
              class="text-[#000000]/70 leading-relaxed font-medium"
              style="font-family: 'Inter', sans-serif;"
            >
              High-performance engineering using modern frameworks to build
              robust systems designed for speed.
            </p>
          </div>
        </a>

        <a
          href="#platform"
          class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px] cursor-pointer block"
        >
          <div>
            <div
              class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              02
            </div>
            <h3
              class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              Custom Business Logic
            </h3>
            <p
              class="text-[#000000]/70 leading-relaxed font-medium"
              style="font-family: 'Inter', sans-serif;"
            >
              Tailored digital workflows and backend systems perfectly aligned
              with your enterprise operational needs.
            </p>
          </div>
        </a>

        <a
          href="#selected-works"
          class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px] cursor-pointer block"
        >
          <div>
            <div
              class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              03
            </div>
            <h3
              class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              Brand Performance
            </h3>
            <p
              class="text-[#000000]/70 leading-relaxed font-medium"
              style="font-family: 'Inter', sans-serif;"
            >
              Optimized digital experiences that maximize conversion rates while
              maintaining rigorous aesthetic standards.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section
    id="platform"
    class="relative bg-white border-t border-black bg-grid-tech"
  >
    <div id="selected-works" class="relative">
      <div
        class="pin-wrap flex gap-32 pl-[15vw] pr-[50vw] items-center h-screen will-change-transform"
      >
        <!-- Section Title Card -->
        <div
          class="flex-shrink-0 w-[40vw] flex items-center justify-start relative will-change-transform"
        >
          <div class="relative">
            <span
              class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block"
              >Case Studies</span
            >
            <h2
              class="text-8xl md:text-9xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              SELECTED<br />WORK
            </h2>
            <div class="mt-8 w-24 h-1 bg-black"></div>
          </div>
        </div>

        <!-- Project Card 1: Reset at 30 -->
        <div
          class="project-card flex-shrink-0 w-[55vw] h-[80vh] flex items-center justify-center relative will-change-transform"
        >
          <!-- Ambient Glow -->
          <div class="absolute inset-0 flex items-center justify-center -z-10">
            <div
              class="w-[60%] h-[60%] bg-[#00ffcc]/10 blur-[100px] rounded-full"
            >
            </div>
          </div>

          <div class="relative w-full max-w-5xl">
            <div
              class="browser-window bg-white border border-black relative z-10 shadow-[20px_20px_0_0_#000000] overflow-hidden"
            >
              <div
                class="h-8 bg-[#f3f3f4] border-b border-black flex items-center px-4 gap-2"
              >
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div
                  class="flex-grow text-[10px] text-black/40 font-mono text-center truncate uppercase tracking-widest pl-4"
                >
                  resetat30.com // active
                </div>
              </div>
              <a
                href="https://resetat30.pages.dev/"
                target="_blank"
                rel="noopener noreferrer"
                class="aspect-[16/10] bg-white relative overflow-hidden block group cursor-pointer"
              >
                <img
                  src="/resetat30.png"
                  alt="Reset at 30"
                  class="w-full h-auto transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
                <div
                  class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center"
                >
                  <span
                    class="bg-white text-black px-4 py-2 text-[10px] font-bold uppercase tracking-widest shadow-lg"
                    >Visit Website ↗</span
                  >
                </div>
              </a>
            </div>

            <!-- Technical Metadata -->
            <div
              class="mt-8 flex items-center justify-between border-b border-black/10 pb-4"
            >
              <div class="flex gap-4">
                <span
                  class="text-[10px] font-bold uppercase tracking-widest text-black"
                  style="font-family: 'Inter', sans-serif;">Astro v4.0</span
                >
                <span
                  class="text-[10px] font-bold uppercase tracking-widest text-black/40"
                  style="font-family: 'Inter', sans-serif;"
                  >Cloudflare Edge</span
                >
              </div>
              <span class="text-[10px] font-mono text-black/20 uppercase"
                >Core_System_01</span
              >
            </div>

            <!-- Mobile Mockup -->
            <div
              class="mobile-mockup absolute -bottom-16 -right-12 w-1/4 max-w-[200px] z-20 border border-black bg-white shadow-[12px_12px_0_0_#000000] will-change-transform"
            >
              <div
                class="p-2 bg-[#f3f3f4] border-b border-black h-4 flex items-center justify-center"
              >
                <div class="w-8 h-1 bg-black/20 rounded-full"></div>
              </div>
              <div class="aspect-[9/19.5] overflow-hidden">
                <img
                  src="/resetat30.png"
                  alt="Mobile View"
                  class="w-full h-full object-cover grayscale brightness-110"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Project Card 2: HM Global -->
        <div
          class="project-card flex-shrink-0 w-[55vw] h-[80vh] flex items-center justify-center relative will-change-transform"
        >
          <!-- Ambient Glow -->
          <div class="absolute inset-0 flex items-center justify-center -z-10">
            <div
              class="w-[60%] h-[60%] bg-[#0066ff]/10 blur-[100px] rounded-full"
            >
            </div>
          </div>

          <div class="relative w-full max-w-5xl">
            <div
              class="browser-window bg-white border border-black relative z-10 shadow-[20px_20px_0_0_#000000] overflow-hidden"
            >
              <div
                class="h-8 bg-[#f3f3f4] border-b border-black flex items-center px-4 gap-2"
              >
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div
                  class="flex-grow text-[10px] text-black/40 font-mono text-center truncate uppercase tracking-widest pl-4"
                >
                  hmglobalinc.com // industrial_node
                </div>
              </div>
              <a
                href="https://hmglobalinc.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="aspect-[16/10] bg-white relative overflow-hidden block group cursor-pointer"
              >
                <img
                  src="/images/hmglobal.png"
                  alt="HM Global - Specialty Materials & Industrial Solutions Dashboard"
                  class="w-full h-auto transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
                <div
                  class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center"
                >
                  <span
                    class="bg-white text-black px-4 py-2 text-[10px] font-bold uppercase tracking-widest shadow-lg"
                    >Visit Website ↗</span
                  >
                </div>
              </a>
            </div>

            <!-- Technical Metadata -->
            <div
              class="mt-8 flex items-center justify-between border-b border-black/10 pb-4"
            >
              <div class="flex gap-4">
                <span
                  class="text-[10px] font-bold uppercase tracking-widest text-black"
                  style="font-family: 'Inter', sans-serif;"
                  >Industrial Solutions</span
                >
                <span
                  class="text-[10px] font-bold uppercase tracking-widest text-black/40"
                  style="font-family: 'Inter', sans-serif;"
                  >Enterprise Architecture</span
                >
              </div>
              <span class="text-[10px] font-mono text-black/20 uppercase"
                >Core_System_02</span
              >
            </div>

            <div
              class="mobile-mockup absolute -bottom-16 -right-12 w-1/4 max-w-[200px] z-20 border border-black bg-white shadow-[12px_12px_0_0_#000000] will-change-transform"
            >
              <div
                class="p-2 bg-[#f3f3f4] border-b border-black h-4 flex items-center justify-center"
              >
                <div class="w-8 h-1 bg-black/20 rounded-full"></div>
              </div>
              <div class="aspect-[9/19.5] overflow-hidden">
                <img
                  src="/images/hmglobal.png"
                  alt="HM Global Mobile View"
                  class="w-full h-full object-cover grayscale brightness-110"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Project Card 3: SecureChoice -->
        <div
          class="project-card flex-shrink-0 w-[55vw] h-[80vh] flex items-center justify-center relative will-change-transform"
        >
          <!-- Ambient Glow -->
          <div class="absolute inset-0 flex items-center justify-center -z-10">
            <div
              class="w-[60%] h-[60%] bg-[#9900ff]/10 blur-[100px] rounded-full"
            >
            </div>
          </div>

          <div class="relative w-full max-w-5xl">
            <div
              class="browser-window bg-white border border-black relative z-10 shadow-[20px_20px_0_0_#000000] overflow-hidden"
            >
              <div
                class="h-8 bg-[#f3f3f4] border-b border-black flex items-center px-4 gap-2"
              >
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-black/20"></div>
                <div
                  class="flex-grow text-[10px] text-black/40 font-mono text-center truncate uppercase tracking-widest pl-4"
                >
                  top-insurance.pages.dev // encrypted
                </div>
              </div>
              <a
                href="https://top-insurance.pages.dev/"
                target="_blank"
                rel="noopener noreferrer"
                class="aspect-[16/10] bg-white relative overflow-hidden block group cursor-pointer"
              >
                <img
                  src="/securechoice.png"
                  alt="SecureChoice Insurance"
                  class="w-full h-auto transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
                <div
                  class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center"
                >
                  <span
                    class="bg-white text-black px-4 py-2 text-[10px] font-bold uppercase tracking-widest shadow-lg"
                    >Visit Website ↗</span
                  >
                </div>
              </a>
            </div>

            <!-- Technical Metadata -->
            <div
              class="mt-8 flex items-center justify-between border-b border-black/10 pb-4"
            >
              <div class="flex gap-4">
                <span
                  class="text-[10px] font-bold uppercase tracking-widest text-black"
                  style="font-family: 'Inter', sans-serif;"
                  >Risk Architecture</span
                >
                <span
                  class="text-[10px] font-bold uppercase tracking-widest text-black/40"
                  style="font-family: 'Inter', sans-serif;"
                  >Security Protocol</span
                >
              </div>
              <span class="text-[10px] font-mono text-black/20 uppercase"
                >Core_System_03</span
              >
            </div>

            <div
              class="mobile-mockup absolute -bottom-16 -right-12 w-1/4 max-w-[200px] z-20 border border-black bg-white shadow-[12px_12px_0_0_#000000] will-change-transform"
            >
              <div
