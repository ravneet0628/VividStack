  <script>
    import Lenis from "lenis";
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { CustomEase } from "gsap/CustomEase";

    gsap.registerPlugin(ScrollTrigger, CustomEase);

    // Register the precise architectural cubic-bezier
    CustomEase.create("architectural", "0.4, 0, 0.2, 1");

    // Initialize Lenis with tuned cinematic smoothing
    const lenis = new Lenis({
      lerp: 0.1,
      wheelMultiplier: 1,
      smoothWheel: true,
    });

    // Sync GSAP ScrollTrigger with Lenis
    lenis.on("scroll", ScrollTrigger.update);

    // Use requestAnimationFrame for Lenis to ensure instant input response
    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    gsap.ticker.lagSmoothing(0);

    const tl = gsap.timeline({
      defaults: { ease: "power4.out", duration: 1.4, force3D: true },
    });

    // Explicitly apply will-change to elements before animation starts to hardware accelerate them
    gsap.set(
      [
        "#main-nav",
        ".hero-char",
        "#hero-title",
        "#hero-subtitle",
        "#hero-cta",
        ".service-card",
        "#selected-works",
        ".project-screenshot",
        ".tech-node",
        "#ambient-elements > div",
      ],
      { willChange: "transform, opacity" },
    );

    tl.to("#main-nav", { opacity: 1, y: 0, delay: 0.2 })
      .from(
        ".hero-char",
        {
          rotationX: 90,
          opacity: 0,
          y: 20,
          stagger: 0.05,
          duration: 1.0,
          ease: "power3.out",
          transformOrigin: "center bottom",
        },
        "-=1.1",
      )
      .to("#hero-title", { opacity: 1, y: 0 }, "-=0.8")
      .to("#hero-subtitle", { opacity: 1, y: 0 }, "-=1.1")
      .to("#hero-cta", { opacity: 1, y: 0 }, "-=1.1")
      .to(".tech-node", { opacity: 1, y: 0, stagger: 0.1 }, "-=1.0");

    // Floating animation for ambient tech elements
    gsap.utils.toArray("#ambient-elements > div").forEach((element) => {
      gsap.to(element, {
        x: "random(-20, 20)",
        y: "random(-20, 20)",
        duration: "random(6, 10)",
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut",
        force3D: true,
      });
    });

    // Floating orbit animation loop for tech nodes
    gsap.utils.toArray(".tech-node").forEach((node, i) => {
      gsap.to(node, {
        y: i % 2 === 0 ? 15 : -15, // Alternate direction
        rotation: i % 2 === 0 ? 1 : -1,
        duration: 2.5 + i * 0.5,
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut",
        force3D: true,
        delay: i * 0.2,
      });
    });

    // Services Slide Animations
    gsap.to(".service-card", {
      scrollTrigger: { trigger: "#services", start: "top 80%" },
      opacity: 1,
      y: 0,
      duration: 1.2,
      stagger: 0.2,
      ease: "power2.out",
      force3D: true,
    });

    // Horizontal Scroll with Pinning for Selected Works
    const worksSection = document.querySelector("#selected-works");
    const pinWrap = document.querySelector(".pin-wrap");

    if (worksSection && pinWrap) {
      const totalWidth = pinWrap.scrollWidth;
      const viewportWidth = window.innerWidth;

      const worksTl = gsap.timeline({
        scrollTrigger: {
          trigger: worksSection,
          start: "top top",
          end: "+=500%", // Balanced for 5 items (Title + 4 Projects)
          pin: true,
          scrub: 1, // Responsive and fluid
          anticipatePin: 1,
          invalidateOnRefresh: true,
        },
      });

      worksTl.to(pinWrap, {
        x: () => -(pinWrap.scrollWidth - window.innerWidth),
        ease: "none", // Constant velocity for maximum smoothness
      });

      // Recalculate ScrollTrigger markers after images and layout have settled
      window.addEventListener("load", () => {
        setTimeout(() => {
          ScrollTrigger.refresh();
        }, 800);
      });

      // Handle resize to keep scroll logic intact
      window.addEventListener("resize", () => {
        ScrollTrigger.refresh();
      });

      // Sub-animation: 1.2x Parallax for Mobile Devices
      gsap.utils.toArray(".mobile-mockup").forEach((mockup) => {
        worksTl.to(
          mockup,
          {
            x: -120, // Precise 1.2x feel glide
            ease: "none",
          },
          0,
        );
      });
    }

    // Smooth Scroll Trigger for Hash Links using Lenis
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        e.preventDefault();
        const targetId = anchor.getAttribute("href");
        if (targetId) {
          lenis.scrollTo(targetId, {
            offset: 0,
            duration: 1.5,
            easing: (t) =>
              Math.min(
                1,
                1.001 *
                  Math.pow(2, -10 * t) *
                  Math.sin((t * 10 - 0.75) * ((2 * Math.PI) / 3)) +
                  1,
              ),
          });
        }
      });
    });

    // Magnetic Hero Headline Letters
    const heroChars = gsap.utils.toArray(".hero-char");

    if (heroChars.length > 0) {
      window.addEventListener("mousemove", (e) => {
        const mouseX = e.clientX;
        const mouseY = e.clientY;

        heroChars.forEach((char) => {
          const rect = char.getBoundingClientRect();
          const charX = rect.left + rect.width / 2;
          const charY = rect.top + rect.height / 2;

          const distX = mouseX - charX;
          const distY = mouseY - charY;
          const distance = Math.sqrt(distX * distX + distY * distY);

          const magnetRadius = 100; // Activation distance in pixels

          if (distance < magnetRadius) {
            // Calculate pull fraction (closer = stronger pull)
            const pull = 1 - distance / magnetRadius;

            // Max displacement is 10px
            const moveX = (distX / distance) * pull * 10;
            const moveY = (distY / distance) * pull * 10;

            gsap.to(char, {
              x: moveX,
              y: moveY,
              rotationY: moveX * 0.5, // Subtle 3D leaning
              rotationX: -moveY * 0.5,
              duration: 0.3,
              ease: "power2.out",
              overwrite: "auto",
            });
          } else {
            // Reset when out of range
            gsap.to(char, {
              x: 0,
              y: 0,
              rotationY: 0,
              rotationX: 0,
              duration: 0.6,
              ease: "power3.out",
              overwrite: "auto",
            });
          }
        });
      });
    }

    // Section Tracer Border Animation
    gsap.utils.toArray(".section-tracer-target").forEach((section) => {
      const tracer = section.querySelector(".section-tracer");
      if (tracer) {
        gsap.to(tracer, {
          scaleX: 1,
          duration: 1.2,
          ease: "power3.inOut",
          force3D: true,
          scrollTrigger: {
            trigger: section,
            start: "top 85%", // Triggers precisely as the section enters the bottom viewport mask
            toggleActions: "play none none reverse",
          },
        });
      }
    });

    // Hero Background Subtle Entrance
    const heroCode = document.querySelector("#hero-background");
    if (heroCode) {
      gsap.from(heroCode, {
        opacity: 0,
        scale: 0.95,
        duration: 3,
        delay: 1,
        ease: "power2.out",
      });
    }

    // Portfolio Staggered Rise Animation
    const portfolioItems = gsap.utils.toArray(".portfolio-item");
    if (portfolioItems.length > 0) {
      gsap.to(portfolioItems, {
        y: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.15,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".portfolio-grid",
          start: "top 80%",
          toggleActions: "play none none reverse",
        },
      });
    }
  </script>
