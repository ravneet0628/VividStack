---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import { Image } from "astro:assets";

import heroCode from "../assets/hero_code.png";
import resetat30Img from "../assets/resetat30.png";
import hmglobalImg from "../assets/hmglobal.png";
import securechoiceImg from "../assets/securechoice.png";
import photolpImg from "../assets/photolp.png";
import lighthouseImg from "../assets/lighthouse-100.png";

const portfolioProjects = [
  {
    title: "Reset at 30",
    category: "Core_System_01",
    stack: "Astro v4.0",
    stack2: "Cloudflare Edge",
    image: resetat30Img,
    accent: "#00ffcc",
    url: "https://resetat30.pages.dev/",
    displayUrl: "resetat30.com // active",
    systemId: "Core_System_01",
    cropY: "-top-[5%]"
  },
  {
    title: "HM Global",
    category: "Industrial Node",
    stack: "Industrial Solutions",
    stack2: "Enterprise Architecture",
    image: hmglobalImg,
    accent: "#0066ff",
    url: "https://hmglobalinc.com/",
    displayUrl: "hmglobalinc.com // industrial_node",
    systemId: "Core_System_02",
    cropY: "top-0"
  },
  {
    title: "Secure Choice",
    category: "Secure API",
    stack: "Risk Architecture",
    stack2: "Security Protocol",
    image: securechoiceImg,
    accent: "#9900ff",
    url: "https://top-insurance.pages.dev/",
    displayUrl: "top-insurance.pages.dev // encrypted",
    systemId: "Core_System_03",
    cropY: "-top-[11%]"
  },
  {
    title: "PhotoLP",
    category: "Asset Node",
    stack: "Creative Delivery",
    stack2: "React + Vite",
    image: photolpImg,
    accent: "#ff9900",
    url: "https://shivstudio.onrender.com/",
    displayUrl: "shivstudio.onrender.com // asset_node",
    systemId: "Core_System_04",
    cropY: "-top-[11%]"
  },
];

---

<Layout title="Premium Web Design & Development — Fast, Responsive Websites">
  <Navbar />

  <main
    class="relative z-0 min-h-screen flex items-center justify-center bg-vivid-cream overflow-hidden text-center px-6"
  >
    <div
      id="ambient-elements"
      class="absolute inset-0 pointer-events-none z-[-1] opacity-5"
    >
      <div
        class="absolute top-[8%] left-[5%] w-48 h-48 md:w-64 md:h-64 text-[#253644] -rotate-12"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="0.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-full h-full"
        >
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="2" y1="20" x2="22" y2="20"></line>
        </svg>
      </div>
      <div
        class="absolute top-[35%] right-[2%] text-[24rem] font-mono leading-none text-[#253644] rotate-[-15deg] select-none opacity-5"
      >
        &#123;
      </div>
      <div
        class="absolute bottom-[20%] right-[15%] text-[24rem] font-mono leading-none text-[#253644] rotate-[15deg] select-none opacity-5"
      >
        &#125;
      </div>
      <div
        class="absolute bottom-[10%] left-[15%] w-72 h-72 border border-[#253644] rotate-45 flex items-center justify-center"
      >
        <div class="w-full h-[1px] bg-[#253644]"></div>
        <div class="absolute h-full w-[1px] bg-[#253644]"></div>
        <div class="absolute w-2/3 h-2/3 border border-[#253644]"></div>
      </div>
    </div>

    <!-- Hero Code Structure Watermark -->
    <div
      id="hero-background"
      class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 w-[200vw] md:w-[85vw] max-w-[1200px] opacity-10 md:opacity-[0.03] pointer-events-none z-[-1] transition-opacity duration-1000"
    >
      <Image
        src={heroCode}
        alt="Code Architecture"
        class="w-full h-auto grayscale opacity-40 md:opacity-100"
        widths={[640, 1280, 1920, 2560]}
        sizes="(max-width: 768px) 100vw, 85vw"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        quality={100}
      />
    </div>

    <!-- Ultra-lightweight Digital Structure Nodes -->
    <div
      class="absolute inset-0 pointer-events-none overflow-hidden mix-blend-multiply hidden md:block"
    >
      <!-- Mint Orb -->
      <div
        class="absolute -top-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full bg-vivid-mint/[0.04] blur-[120px] animate-pulse"
        style="animation-duration: 4s;"
      >
      </div>
      <!-- Core Navy Node -->
      <div
        class="absolute top-[40%] -left-[15%] w-[50vw] h-[50vw] rounded-full bg-[#253644]/[0.03] blur-[140px]"
      >
      </div>
      <!-- Center Anchor -->
      <div
        class="absolute top-[20%] left-[30%] w-[30vw] h-[30vw] rounded-full bg-[#253644]/[0.02] blur-[100px] animate-pulse"
        style="animation-duration: 6s;"
      >
      </div>
    </div>

    <!-- Floating Brutalist Tech Nodes -->
    <div
      class="tech-node absolute top-[12%] sm:top-[30%] md:top-[40%] left-[4%] md:left-[8%] bg-white/95 backdrop-blur-sm border border-[#253644] p-2 md:p-5 rounded-none shadow-[4px_4px_0_0_#253644] md:shadow-[10px_10px_0_0_#253644] w-36 md:w-52 text-left opacity-0 translate-y-8 flex flex-col scale-90 md:scale-100"
    >
      <div
        class="flex items-center gap-3 mb-2 border-b border-[#253644]/10 pb-3"
      >
        <div
          class="w-3 h-3 rounded-none bg-[#95cbd0] shadow-[1px_1px_0_0_#253644]"
        >
        </div>
        <span
          class="text-[0.65rem] font-bold uppercase tracking-[0.25em] text-[#253644]"
          >Health_State</span
        >
      </div>
      <div class="text-[#253644] font-mono text-sm font-bold tracking-tight">
        SYS_NOMINAL
      </div>
    </div>

    <div
      class="tech-node absolute bottom-[8%] sm:bottom-[15%] md:bottom-[18%] right-[6%] md:right-[12%] bg-[#253644] border border-[#253644] p-3 md:p-6 rounded-none shadow-[6px_6px_0_0_#95cbd0] md:shadow-[12px_12px_0_0_#95cbd0] w-40 md:w-64 text-left opacity-0 translate-y-8 flex flex-col scale-90 md:scale-100"
    >
      <div class="flex justify-between items-center mb-4">
        <div
          class="text-[0.65rem] font-bold uppercase tracking-widest text-white/50"
        >
          Edge Latency
        </div>
        <div class="text-[#95cbd0] font-mono text-sm font-bold">12ms</div>
      </div>
      <div
        class="w-full bg-white/5 h-2 rounded-none overflow-hidden border border-white/10"
      >
        <div class="w-[20%] bg-[#95cbd0] h-full shadow-[1px_0_0_#000000]"></div>
      </div>
    </div>

    <div
      class="tech-node absolute top-[18%] right-[4%] lg:right-[5%] bg-white backdrop-blur-md border border-[#253644] p-4 rounded-none shadow-[8px_8px_0_0_#253644] hidden lg:flex items-center gap-5 opacity-0 translate-y-8"
    >
      <div
        class="w-10 h-10 flex items-center justify-center bg-[#253644] text-[#95cbd0] font-mono text-base font-bold shadow-[3px_3px_0_0_#95cbd0]"
      >
        99
      </div>
      <div class="flex flex-col">
        <span
          class="text-[0.65rem] font-bold uppercase tracking-[0.3em] text-[#253644]"
          >Architecture</span
        >
        <span
          class="text-[0.6rem] font-bold uppercase tracking-[0.2em] text-[#253644]/40"
          >Score_P76</span
        >
      </div>
    </div>

    <div class="z-10 w-full max-w-7xl mx-auto flex flex-col items-center">
      <div id="hero-brand" class="mb-4" style="perspective: 1000px;">
        <h1
          class="text-6xl sm:text-8xl md:text-[7rem] lg:text-[9rem] font-extrabold tracking-tighter uppercase leading-none drop-shadow-sm flex flex-wrap justify-center gap-x-[2vw]"
        >
          <span class="text-[#253644] flex">
            {
              "Vivid"
                .split("")
                .map((char) => (
                  <span class="hero-char inline-block will-change-transform">
                    {char}
                  </span>
                ))
            }
          </span>
          <span class="text-[#95cbd0] flex">
            {
              "Stack"
                .split("")
                .map((char) => (
                  <span class="hero-char inline-block will-change-transform">
                    {char}
                  </span>
                ))
            }
          </span>
        </h1>
      </div>
      <h2
        id="hero-title"
        class="text-lg sm:text-xl md:text-2xl font-bold tracking-[0.2em] text-[#253644] uppercase opacity-0 translate-y-12 mt-2"
      >
        UNCOMPROMISING DIGITAL <span class="text-[#95cbd0]">ARCHITECTURE.</span>
      </h2>

      <p
        id="hero-subtitle"
        class="mt-8 md:mt-10 text-base sm:text-xl md:text-2xl lg:text-3xl text-vivid-navy/70 font-medium tracking-wide opacity-0 translate-y-8 max-w-3xl px-2"
      >
        High-performance web systems for ambitious businesses.
      </p>

      <div id="hero-cta" class="mt-12 md:mt-16 opacity-0 translate-y-8">
        <a
          href="#portfolio"
          class="group relative inline-flex items-center gap-3 px-10 py-5 bg-vivid-navy text-vivid-cream rounded-full overflow-hidden transition-all hover:pr-14 hover:scale-105 duration-300 shadow-[0_10px_30px_rgba(37,54,68,0.2)]"
        >
          <span
            class="relative z-10 font-bold uppercase tracking-widest text-sm md:text-base"
            >Explore the Stack</span
          >
          <div
            class="absolute right-5 translate-x-10 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 font-bold text-lg text-vivid-mint"
          >
            →
          </div>
        </a>
      </div>
    </div>
  </main>

  <section
    id="services"
    class="section-tracer-target relative pt-6 md:pt-16 pb-32 lg:pt-24 bg-white overflow-hidden"
  >
    <div
      class="section-tracer absolute top-0 left-0 w-full h-px bg-[#000000] origin-left scale-x-0 z-20 will-change-transform"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="mb-20 text-center">
        <span
          class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block"
          >Our Expertise</span
        >
        <h2
          class="text-6xl md:text-8xl font-black tracking-tighter uppercase text-black leading-[0.85] select-none"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          Services
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 md:gap-12">
        <a
          href="#portfolio"
          class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px] cursor-pointer block"
        >
          <div>
            <div
              class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              01
            </div>
            <h3
              class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              Scalable Architecture
            </h3>
            <p
              class="text-[#000000]/70 leading-relaxed font-medium"
              style="font-family: 'Inter', sans-serif;"
            >
              High-performance engineering using modern frameworks to build
              robust systems designed for speed.
            </p>
          </div>
        </a>

        <a
          href="#platform"
          class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px] cursor-pointer block"
        >
          <div>
            <div
              class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              02
            </div>
            <h3
              class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              Custom Business Logic
            </h3>
            <p
              class="text-[#000000]/70 leading-relaxed font-medium"
              style="font-family: 'Inter', sans-serif;"
            >
              Tailored digital workflows and backend systems perfectly aligned
              with your enterprise operational needs.
            </p>
          </div>
        </a>

        <a
          href="#selected-works"
          class="service-card flex flex-col justify-between group bg-[#f3f3f4] border border-[#000000] p-10 md:p-14 rounded-none transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#006a63] shadow-[0_10px_30px_rgba(0,0,0,0.04)] opacity-0 translate-y-[100px] cursor-pointer block"
        >
          <div>
            <div
              class="text-[#000000]/20 text-5xl font-extrabold mb-6 group-hover:text-[#006a63]/30 transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              03
            </div>
            <h3
              class="text-xl lg:text-2xl font-bold mb-4 uppercase tracking-tight text-[#000000] group-hover:text-[#006a63] transition-colors duration-150 ease-[cubic-bezier(0.4,0,0.2,1)]"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              Brand Performance
            </h3>
            <p
              class="text-[#000000]/70 leading-relaxed font-medium"
              style="font-family: 'Inter', sans-serif;"
            >
              Optimized digital experiences that maximize conversion rates while
              maintaining rigorous aesthetic standards.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section
    id="platform"
    class="relative bg-white border-t border-black bg-grid-tech"
  >
    <div id="selected-works" class="relative">

      <!-- Section-Level Sticky Browser Chrome -->
      <div class="selected-works-chrome">
        <div class="chrome-dots">
          <div class="chrome-dot dot-red"></div>
          <div class="chrome-dot dot-yellow"></div>
          <div class="chrome-dot dot-green"></div>
        </div>
        <div class="chrome-label">vividstack.io // selected_works</div>
        <span class="chrome-badge">CASE STUDIES</span>
      </div>

      <!-- Centered Header for Mobile -->
      <div class="mobile-section-header w-full text-center pt-16 pb-4">
        <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block">Case Studies</span>
        <h2
          class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          SELECTED WORK
        </h2>
        <div class="mt-8 w-16 h-1 bg-black mx-auto"></div>
      </div>

      <!-- Desktop: GSAP Pin Wrap | Mobile: Snap Scroll -->
      <div class="pin-wrap" id="pin-wrap">

        <!-- Section Title Card (Desktop Only) -->
        <div class="title-card will-change-transform">
          <div class="relative">
            <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block">Case Studies</span>
            <h2
              class="text-6xl md:text-8xl md:text-9xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none"
              style="font-family: 'Space Grotesk', sans-serif;"
            >
              SELECTED<br />WORK
            </h2>
            <div class="mt-8 w-24 h-1 bg-black"></div>
          </div>
        </div>

        {portfolioProjects.map((project) => (
          <div class="project-card will-change-transform">
            <!-- Ambient Glow -->
            <div class="absolute inset-0 flex items-center justify-center -z-10">
              <div
                class="w-[60%] h-[60%] blur-[100px] rounded-full"
                style={`background: ${project.accent}20;`}
              ></div>
            </div>

            <div class="project-card-inner">
              <!-- Browser Window (no dots — they are in the section chrome above) -->
              <div class="browser-window">
                <!-- URL bar only (no traffic lights) -->
                <div class="browser-url-bar">
                  <div class="url-text">{project.displayUrl}</div>
                </div>

                <!-- Project Screenshot -->
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-screenshot-link group"
                >
                  <Image
                    src={project.image}
                    alt={project.title}
                    class="project-screenshot-img"
                    widths={[600, 1200, 1800, 2400]}
                    sizes="(max-width: 1024px) 90vw, 60vw"
                    loading="lazy"
                    decoding="async"
                    quality={100}
                  />
                  <div class="screenshot-overlay">
                    <span class="screenshot-cta">Visit Website ↗</span>
                  </div>
                </a>
              </div>

              <!-- Technical Metadata -->
              <div class="project-meta">
                <div class="meta-stack">
                  <span class="meta-primary">{project.stack}</span>
                  <span class="meta-secondary">{project.stack2}</span>
                </div>
                <span class="meta-id">{project.systemId}</span>
              </div>

              <!-- Blueprint Terminal: Brutalist Architecture Sidebar (Desktop Only) -->
              <div class="blueprint-terminal will-change-transform hidden md:block">
                <!-- Power-Up Glow (Behind) -->
                <div class="terminal-glow" style={`background: ${project.accent};`}></div>
                
                <div class="terminal-header">
                  <span class="status-dot animate-pulse" style={`background: ${project.accent};`}></span>
                  <span class="status-code">{project.systemId}_ACTIVE</span>
                </div>

                <div class="terminal-logs">
                  <div class="log-line">
                    <span class="log-label">LHR_STATE</span>
                    <span class="log-value" style={`color: ${project.accent};`}>99</span>
                  </div>
                  <div class="log-line">
                    <span class="log-label">NODE_SYNC</span>
                    <span class="log-value">TRUE</span>
                  </div>
                  <div class="log-line">
                    <span class="log-label">PROTOCOL</span>
                    <span class="log-value">{project.stack.split(" ")[0].toUpperCase()}</span>
                  </div>
                  <div class="log-line">
                    <span class="log-label">CORE_P76</span>
                    <span class="log-value">NOMINAL</span>
                  </div>
                </div>

                <div class="terminal-footer" style={`border-top-color: ${project.accent}40;`}>
                  <div class="tech-badge" style={`color: ${project.accent};`}>
                    // AUTHENTIC_STACK
                  </div>
                </div>
              </div>

            </div>
          </div>
        ))}

      </div>
    </div>

    <section
      id="process"
      class="section-tracer-target relative py-32 bg-[#f3f3f4] overflow-hidden"
    >
      <div
        class="section-tracer absolute top-0 left-0 w-full h-px bg-[#000000] origin-left scale-x-0 z-20 will-change-transform"
      >
      </div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="mb-24 md:mb-32">
          <span
            class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block"
            >How We Work</span
          >
          <h2
            class="text-6xl md:text-8xl font-black tracking-tighter uppercase text-black leading-[0.85] select-none"
            style="font-family: 'Space Grotesk', sans-serif;"
          >
            The Process
          </h2>
        </div>

        <div class="process-split-container relative">
          <!-- Central Vertical Line -->
          <div class="process-vertical-line"></div>

          <!-- Stage 01 -->
          <div class="process-row grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-24 relative mb-24 last:mb-0">
            <div class="process-stage-label">PHASE 01</div>
            <!-- Left: YOU (Client) -->
            <div class="process-column-you">
              <div class="process-card glass-panel text-left">
                <span class="process-label client">YOU</span>
                <h3 class="process-title">Submit Brief</h3>
                <p class="process-description">Define goals, target audience, and core functional requirements.</p>
              </div>
            </div>

            <!-- Central Icon -->
            <div class="process-icon-wrapper">
              <div class="process-icon-glow">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
              </div>
            </div>

            <!-- Right: WE (Vivid Stack) -->
            <div class="process-column-we">
              <div class="process-card glass-panel agency-card text-left">
                <span class="process-label agency">WE</span>
                <h3 class="process-title">Strategic Analysis</h3>
                <p class="process-description">Comprehensive technical audit and architectural blueprinting.</p>
              </div>
            </div>
          </div>

          <!-- Stage 02 -->
          <div class="process-row grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-24 relative mb-24 last:mb-0">
            <div class="process-stage-label">PHASE 02</div>
            <!-- Left: YOU (Client) -->
            <div class="process-column-you">
              <div class="process-card glass-panel text-left">
                <span class="process-label client">YOU</span>
                <h3 class="process-title">Asset Delivery</h3>
                <p class="process-description">Provide brand guides, content, and existing data schemas.</p>
              </div>
            </div>

            <!-- Central Icon -->
            <div class="process-icon-wrapper">
              <div class="process-icon-glow">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                  <polygon points="12,2 22,12 12,22 2,12"/>
                </svg>
              </div>
            </div>

            <!-- Right: WE (Vivid Stack) -->
            <div class="process-column-we">
              <div class="process-card glass-panel agency-card text-left">
                <span class="process-label agency">WE</span>
                <h3 class="process-title">Infrastructure Setup</h3>
                <p class="process-description">Initializing high-performance edge environments and CDNs.</p>
              </div>
            </div>
          </div>

          <!-- Stage 03 -->
          <div class="process-row grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-24 relative mb-24 last:mb-0">
            <div class="process-stage-label">PHASE 03</div>
            <!-- Left: YOU (Client) -->
            <div class="process-column-you">
              <div class="process-card glass-panel text-left">
                <span class="process-label client">YOU</span>
                <h3 class="process-title">Feedback Loop</h3>
                <p class="process-description">Continuous review of iterative builds and design systems.</p>
              </div>
            </div>

