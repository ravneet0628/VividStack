---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import { Image } from "astro:assets";

import heroCode from "../assets/hero_code.png";
import resetat30Img from "../assets/resetat30.png";
import hmglobalImg from "../assets/hmglobal.png";
import securechoiceImg from "../assets/securechoice.png";
import photolpImg from "../assets/photolp.png";
import lighthouseImg from "../assets/lighthouse-100.png";

import resetat30Mobile from "../assets/resetat30_mobile.png";
import hmglobalMobile from "../assets/hmglobal_mobile.png";
import securechoiceMobile from "../assets/securechoice_mobile.png";
import photolpMobile from "../assets/photolp_mobile.png";

const portfolioProjects = [
  {
    title: "Reset at 30",
    category: "Personal Brand",
    stack: "Lifestyle Blog",
    stack2: "Loads in under 1 second",
    image: resetat30Img,
    mobileImage: resetat30Mobile,
    accent: "#00ffcc",
    url: "https://resetat30.pages.dev/",
    displayUrl: "resetat30.com",
    systemId: "Personal Brand Website",
    cropY: "-top-[5%]"
  },
  {
    title: "HM Global",
    category: "Corporate",
    stack: "Industrial Services",
    stack2: "Built to grow with the business",
    image: hmglobalImg,
    mobileImage: hmglobalMobile,
    accent: "#0066ff",
    url: "https://hmglobalinc.com/",
    displayUrl: "hmglobalinc.com",
    systemId: "Corporate Website",
    cropY: "top-0"
  },
  {
    title: "Secure Choice",
    category: "Insurance",
    stack: "Insurance Agency",
    stack2: "Looks trustworthy, converts leads",
    image: securechoiceImg,
    mobileImage: securechoiceMobile,
    accent: "#9900ff",
    url: "https://top-insurance.pages.dev/",
    displayUrl: "top-insurance.pages.dev",
    systemId: "Insurance Website",
    cropY: "-top-[11%]"
  },
  {
    title: "PhotoLP",
    category: "Photography",
    stack: "Photography Portfolio",
    stack2: "Showcases work beautifully",
    image: photolpImg,
    mobileImage: photolpMobile,
    accent: "#ff9900",
    url: "https://shivstudio.onrender.com/",
    displayUrl: "shivstudio.onrender.com",
    systemId: "Photography Portfolio",
    cropY: "-top-[11%]"
  },
];

---

<Layout title="Premium Web Design & Development — Fast, Responsive Websites">
  <Navbar />

  <main
    class="relative z-0 min-h-screen flex items-center justify-center bg-vivid-cream overflow-hidden text-center px-6"
  >
    <div
      id="ambient-elements"
      class="absolute inset-0 pointer-events-none z-[-1] opacity-5"
    >
      <div
        class="absolute top-[8%] left-[5%] w-48 h-48 md:w-64 md:h-64 text-[#253644] -rotate-12"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="0.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-full h-full"
        >
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="2" y1="20" x2="22" y2="20"></line>
        </svg>
      </div>
      <div
        class="absolute top-[35%] right-[2%] text-[24rem] font-mono leading-none text-[#253644] rotate-[-15deg] select-none opacity-5"
      >
        &#123;
      </div>
      <div
        class="absolute bottom-[20%] right-[15%] text-[24rem] font-mono leading-none text-[#253644] rotate-[15deg] select-none opacity-5"
      >
        &#125;
      </div>
      <div
        class="absolute bottom-[10%] left-[15%] w-72 h-72 border border-[#253644] rotate-45 flex items-center justify-center"
      >
        <div class="w-full h-[1px] bg-[#253644]"></div>
        <div class="absolute h-full w-[1px] bg-[#253644]"></div>
        <div class="absolute w-2/3 h-2/3 border border-[#253644]"></div>
      </div>
    </div>

    <!-- Hero Code Structure Watermark -->
    <div
      id="hero-background"
      class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 w-[200vw] md:w-[85vw] max-w-[1200px] opacity-10 md:opacity-[0.03] pointer-events-none z-[-1] transition-opacity duration-1000"
    >
      <Image
        src={heroCode}
        alt="Code Architecture"
        class="w-full h-auto grayscale opacity-40 md:opacity-100"
        widths={[640, 1280, 1920, 2560]}
        sizes="(max-width: 768px) 100vw, 85vw"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        quality={100}
      />
    </div>

    <!-- Ultra-lightweight Digital Structure Nodes -->
    <div
      class="absolute inset-0 pointer-events-none overflow-hidden mix-blend-multiply hidden md:block"
    >
      <!-- Mint Orb -->
      <div
        class="absolute -top-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full bg-vivid-mint/[0.04] blur-[120px] animate-pulse"
        style="animation-duration: 4s;"
      >
      </div>
      <!-- Core Navy Node -->
      <div
        class="absolute top-[40%] -left-[15%] w-[50vw] h-[50vw] rounded-full bg-[#253644]/[0.03] blur-[140px]"
      >
      </div>
      <!-- Center Anchor -->
      <div
        class="absolute top-[20%] left-[30%] w-[30vw] h-[30vw] rounded-full bg-[#253644]/[0.02] blur-[100px] animate-pulse"
        style="animation-duration: 6s;"
      >
      </div>
    </div>

    <!-- Floating Brutalist Tech Nodes -->
    <div
      class="tech-node absolute top-[12%] sm:top-[30%] md:top-[40%] left-[4%] md:left-[8%] bg-white/95 backdrop-blur-sm border border-[#253644] p-2 md:p-5 rounded-none shadow-[4px_4px_0_0_#253644] md:shadow-[10px_10px_0_0_#253644] w-36 md:w-52 text-left opacity-0 translate-y-8 flex flex-col scale-90 md:scale-100"
    >
      <div
        class="flex items-center gap-3 mb-2 border-b border-[#253644]/10 pb-3"
      >
        <div
          class="w-3 h-3 rounded-none bg-[#95cbd0] shadow-[1px_1px_0_0_#253644]"
        >
        </div>
        <span
          class="text-[0.65rem] font-bold uppercase tracking-[0.25em] text-[#253644]"
          >Projects Shipped</span
        >
      </div>
      <div class="text-[#253644] text-2xl md:text-3xl font-black tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">
        4+
      </div>
    </div>

    <div
      class="tech-node absolute bottom-[8%] sm:bottom-[15%] md:bottom-[18%] right-[6%] md:right-[12%] bg-[#253644] border border-[#253644] p-3 md:p-6 rounded-none shadow-[6px_6px_0_0_#95cbd0] md:shadow-[12px_12px_0_0_#95cbd0] w-40 md:w-64 text-left opacity-0 translate-y-8 flex flex-col scale-90 md:scale-100"
    >
      <div class="flex justify-between items-center mb-4">
        <div
          class="text-[0.65rem] font-bold uppercase tracking-widest text-white/50"
        >
          Page Load Time
        </div>
        <div class="text-[#95cbd0] font-bold text-sm" style="font-family: 'Space Grotesk', sans-serif;">< 1 sec</div>
      </div>
      <div
        class="w-full bg-white/5 h-2 rounded-none overflow-hidden border border-white/10"
      >
        <div class="w-[95%] bg-[#95cbd0] h-full shadow-[1px_0_0_#000000]"></div>
      </div>
    </div>

    <div
      class="tech-node absolute top-[18%] right-[4%] lg:right-[5%] bg-white backdrop-blur-md border border-[#253644] p-4 rounded-none shadow-[8px_8px_0_0_#253644] hidden lg:flex items-center gap-5 opacity-0 translate-y-8"
    >
      <div
        class="w-10 h-10 flex items-center justify-center bg-[#253644] text-[#95cbd0] text-base font-black shadow-[3px_3px_0_0_#95cbd0]" style="font-family: 'Space Grotesk', sans-serif;"
      >
        100
      </div>
      <div class="flex flex-col">
        <span
          class="text-[0.65rem] font-bold uppercase tracking-[0.3em] text-[#253644]"
          >Lighthouse</span
        >
        <span
          class="text-[0.6rem] font-bold uppercase tracking-[0.2em] text-[#253644]/40"
          >Perfect Score</span
        >
      </div>
    </div>

    <div class="z-10 w-full max-w-7xl mx-auto flex flex-col items-center">
      <div id="hero-brand" class="mb-4" style="perspective: 1000px;">
        <h1
          class="text-6xl sm:text-8xl md:text-[7rem] lg:text-[9rem] font-extrabold tracking-tighter uppercase leading-none drop-shadow-sm flex flex-wrap justify-center gap-x-[2vw]"
        >
          <span class="text-[#253644] flex">
            {
              "Vivid"
                .split("")
                .map((char) => (
                  <span class="hero-char inline-block will-change-transform">
                    {char}
                  </span>
                ))
            }
          </span>
          <span class="text-[#95cbd0] flex">
            {
              "Stack"
                .split("")
                .map((char) => (
                  <span class="hero-char inline-block will-change-transform">
                    {char}
                  </span>
                ))
            }
          </span>
        </h1>
      </div>
      <h2
        id="hero-title"
        class="text-lg sm:text-xl md:text-2xl font-bold tracking-[0.2em] text-[#253644] uppercase opacity-0 translate-y-12 mt-2"
      >
        WE BUILD WEBSITES THAT <span class="text-[#95cbd0]">WIN CUSTOMERS.</span>
      </h2>

      <p
        id="hero-subtitle"
        class="mt-8 md:mt-10 text-base sm:text-xl md:text-2xl lg:text-3xl text-vivid-navy/70 font-medium tracking-wide opacity-0 translate-y-8 max-w-3xl px-2"
      >
        Beautiful, fast websites for businesses that want to grow.
      </p>

      <div id="hero-cta" class="mt-12 md:mt-16 opacity-0 translate-y-8">
        <a
          href="#portfolio"
          class="group relative inline-flex items-center gap-3 px-10 py-5 bg-vivid-navy text-vivid-cream overflow-hidden transition-all hover:pr-14 duration-300 border-2 border-vivid-navy shadow-[6px_6px_0_0_#000] hover:shadow-[10px_10px_0_0_#000] hover:-translate-y-1"
        >
          <span
            class="relative z-10 font-bold uppercase tracking-widest text-sm md:text-base"
            >See Our Work</span
          >
          <div
            class="absolute right-5 translate-x-10 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 font-bold text-lg text-vivid-mint"
          >
            →
          </div>
        </a>
      </div>
    </div>
  </main>

  <section id="advantage" class="relative py-24 bg-white overflow-hidden border-b border-black/5 bg-grid-tech">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="mb-16 text-center">
        <span
          class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block"
          >Why Choose Us</span
        >
        <h2
          class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          THE VIVID ADVANTAGE_
        </h2>
        <p class="text-vivid-navy/60 font-medium text-lg md:text-xl tracking-tight max-w-2xl mx-auto mt-8">
          Everything your website needs to look great and bring in customers.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-16">
        <!-- Card 1: Blazing Speed -->
        <div class="advantage-card group bg-[#f8f9fa] border border-black p-8 md:p-10 shadow-[8px_8px_0_0_#000] hover:shadow-[12px_12px_0_0_#000] transform hover:-translate-y-1">
          <div class="w-12 h-12 bg-vivid-navy text-vivid-mint flex items-center justify-center mb-6 shadow-[4px_4px_0_0_#00ffcc]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3 class="text-xl font-black uppercase tracking-tighter mb-4 leading-tight" style="font-family: 'Space Grotesk', sans-serif;">BLAZING FAST<br/>PERFORMANCE</h3>
          <p class="text-vivid-navy/70 font-medium leading-relaxed" style="font-family: 'Inter', sans-serif;">Most users leave a slow site. Yours will load in under a second, keeping every customer on the page.</p>
        </div>

        <!-- Card 2: Visibility -->
        <div class="advantage-card group bg-[#f8f9fa] border border-black p-8 md:p-10 shadow-[8px_8px_0_0_#000] hover:shadow-[12px_12px_0_0_#000] transform hover:-translate-y-1">
          <div class="w-12 h-12 bg-white text-black flex items-center justify-center mb-6 border border-black shadow-[4px_4px_0_0_#000]">
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor">
              <path d="M12.48 10.92v3.28h7.84c-.24 1.84-2.21 5.39-7.84 5.39-4.84 0-8.77-4.01-8.77-8.96s3.93-8.96 8.77-8.96c2.75 0 4.6 1.17 5.65 2.18l2.59-2.5c-1.66-1.55-3.82-2.48-6.24-2.48-5.32 0-9.67 4.35-9.67 9.67s4.35 9.67 9.67 9.67c5.56 0 9.25-3.91 9.25-9.41 0-.63-.07-1.12-.15-1.59h-9.1z"/>
            </svg>
          </div>
          <h3 class="text-xl font-black uppercase tracking-tighter mb-4 leading-tight" style="font-family: 'Space Grotesk', sans-serif;">FOUND ON<br/>GOOGLE</h3>
          <p class="text-vivid-navy/70 font-medium leading-relaxed" style="font-family: 'Inter', sans-serif;">We handle the technical SEO setup so your business shows up where it matters.</p>
        </div>

        <!-- Card 3: Free Hosting -->
        <div class="advantage-card group bg-vivid-navy border border-vivid-mint p-8 md:p-10 shadow-[8px_8px_0_0_#00ffcc] hover:shadow-[12px_12px_0_0_#00ffcc] transform hover:-translate-y-1 relative">
          <div class="absolute -top-4 -right-4 bg-white text-vivid-navy font-black text-[10px] px-3 py-1.5 border-2 border-vivid-mint shadow-[4px_4px_0_0_#00ffcc] z-20 tracking-widest uppercase free-badge">FREE FOREVER</div>
          <div class="w-12 h-12 bg-vivid-mint text-vivid-navy flex items-center justify-center mb-6 shadow-[4px_4px_0_0_#ffffff]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="text-xl font-black uppercase tracking-tighter mb-4 leading-tight text-white" style="font-family: 'Space Grotesk', sans-serif;">$0 HOSTING.<br/><span class="text-vivid-mint">FREE FOREVER</span></h3>
          <p class="text-white/70 font-medium leading-relaxed" style="font-family: 'Inter', sans-serif;">Save thousands in monthly fees with our enterprise-grade infrastructure.</p>
        </div>
      </div>
    </div>
  </section>

  <section
    id="services"
    class="section-tracer-target relative py-24 lg:py-32 bg-[#f3f3f4] overflow-hidden"
  >
    <div
      class="section-tracer absolute top-0 left-0 w-full h-px bg-[#000000] origin-left scale-x-0 z-20 will-change-transform"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="mb-16">
        <span
          class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block"
          >Our Expertise</span
        >
        <h2
          class="text-6xl md:text-8xl font-black tracking-tighter uppercase text-black leading-[0.85] select-none"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          Services
        </h2>
      </div>

      <!-- BENTO GRID -->
      <div class="bento-grid">

        <!-- Large hero tile: Web Engineering -->
        <a href="#platform" class="bento-tile bento-hero service-card group" id="bento-engineering">
          <div class="bento-number">01</div>
          <div class="bento-content">
            <div class="bento-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
                <polyline points="16 18 22 12 16 6"/>
                <polyline points="8 6 2 12 8 18"/>
              </svg>
            </div>
            <h3 class="bento-title">Web Engineering</h3>
            <p class="bento-desc">Your website will load instantly, look stunning on every screen, and grow with your business. No compromises.</p>
            <span class="bento-cta">View Case Studies →</span>
          </div>
          <div class="bento-bg-glow" style="background: #00ffcc;"></div>
        </a>

        <!-- Secondary tile: Technical SEO -->
        <div class="bento-tile bento-secondary service-card group" id="bento-seo">
          <div class="bento-number">02</div>
          <div class="bento-content">
            <div class="bento-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
            </div>
            <h3 class="bento-title">Technical SEO</h3>
            <p class="bento-desc">We set up your site so Google can find your business — the technical stuff that actually gets you more customers.</p>
          </div>
          <div class="bento-bg-glow" style="background: #0066ff;"></div>
        </div>

        <!-- Accent tile: UI / UX Design -->
        <div class="bento-tile bento-accent service-card group" id="bento-design">
          <div class="bento-number">03</div>
          <div class="bento-content">
            <div class="bento-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
                <path d="M12 20h9"/>
                <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
            </div>
            <h3 class="bento-title">UI / UX Design</h3>
            <p class="bento-desc">Interfaces designed to turn visitors into paying customers. Every detail serves a purpose.</p>
          </div>
          <div class="bento-bg-glow" style="background: #9900ff;"></div>
        </div>

      </div>
    </div>
  </section>

  <section
    id="platform"
    class="relative bg-white border-t border-black bg-grid-tech"
  >
    <div id="selected-works" class="relative">

      <!-- Section-Level Sticky Browser Chrome -->
      <div class="selected-works-chrome">
        <div class="chrome-dots">
          <div class="chrome-dot dot-red"></div>
          <div class="chrome-dot dot-yellow"></div>
          <div class="chrome-dot dot-green"></div>
        </div>
        <div class="chrome-label">vividstack.io // our work</div>
        <span class="chrome-badge">CASE STUDIES</span>
      </div>

      <!-- Centered Header for Mobile -->
      <div class="mobile-section-header w-full text-center pt-16 pb-4">
        <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block">Case Studies</span>
        <h2
          class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          SELECTED WORK
        </h2>
        <div class="mt-8 w-16 h-1 bg-black mx-auto"></div>
      </div>

      <!-- Desktop: GSAP Pin Wrap | Mobile: Snap Scroll -->
      <div class="pin-wrap" id="pin-wrap">

        <!-- Title card: first slide in the horizontal scroll -->
        <div class="title-card will-change-transform">
          <span class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-3 block">Case Studies</span>
          <h2
            class="text-6xl xl:text-8xl font-black uppercase tracking-tighter text-black leading-[0.85] select-none"
            style="font-family: 'Space Grotesk', sans-serif;"
          >
            SELECTED<br />WORK
          </h2>
          <div class="mt-6 w-20 h-1 bg-black"></div>
        </div>
        {portfolioProjects.map((project) => (
          <div class="project-card will-change-transform">

            <div class="project-card-inner">
              <!-- Dual-Device Container: strictly 16/9 -->
              <div class="dual-device-container">

                <!-- Layer 1 (back): Desktop Browser -->
                <div class="desktop-browser">
                  <!-- URL bar with traffic-light dots -->
                  <div class="desktop-url-bar">
                    <div class="chrome-dot-sm dot-red"></div>
                    <div class="chrome-dot-sm dot-yellow"></div>
                    <div class="chrome-dot-sm dot-green"></div>
                    <div class="desktop-url-text">{project.displayUrl}</div>
                  </div>
                  <!-- Screenshot -->
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="desktop-screenshot-link group"
                  >
                    <Image
                      src={project.image}
                      alt={project.title}
                      class="desktop-screenshot-img"
                      widths={[600, 1200, 1800]}
                      sizes="(max-width: 1024px) 90vw, 60vw"
                      loading="lazy"
                      decoding="async"
                      quality={95}
                    />
                    <div class="screenshot-overlay">
                      <span class="screenshot-cta">Visit Website ↗</span>
                    </div>
                  </a>
                </div>

                <!-- Layer 2 (front): Mobile Phone Frame -->
                <div class="phone-frame">
                  <div class="phone-notch"></div>
                  <div class="phone-screen">
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class="block w-full h-full overflow-hidden">
                      <Image
                        src={project.mobileImage}
                        alt={`${project.title} mobile`}
                        class="phone-screenshot-img"
                        widths={[390, 780]}
                        sizes="(max-width: 1024px) 30vw, 15vw"
                        loading="lazy"
                        decoding="async"
                        quality={90}
                      />
                    </a>
                  </div>
                  <div class="phone-home-bar"></div>
                </div>

                <!-- Accent glow behind the container -->
                <div class="device-glow" style={`background: ${project.accent};`}></div>
              </div>

              <!-- Project Metadata — below the 16/9 box -->
              <div class="project-meta">
                <div class="meta-stack">
                  <span class="meta-primary">{project.stack}</span>
                  <span class="meta-secondary">{project.stack2}</span>
                </div>
                <span class="meta-id">{project.systemId}</span>
              </div>
            </div>

          </div>
        ))}

      </div>
    </div>

    <section
      id="process"
      class="section-tracer-target relative py-32 bg-[#f3f3f4] overflow-hidden"
    >
      <div
        class="section-tracer absolute top-0 left-0 w-full h-px bg-[#000000] origin-left scale-x-0 z-20 will-change-transform"
      >
      </div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="mb-24 md:mb-32">
          <span
            class="text-vivid-mint font-bold uppercase tracking-[0.4em] text-sm mb-4 block"
            >How We Work</span
          >
          <h2
            class="text-6xl md:text-8xl font-black tracking-tighter uppercase text-black leading-[0.85] select-none"
            style="font-family: 'Space Grotesk', sans-serif;"
          >
            The Process
          </h2>
        </div>

