  <script>
    import Lenis from "lenis";
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { CustomEase } from "gsap/CustomEase";

    gsap.registerPlugin(ScrollTrigger, CustomEase);

    // Register the precise architectural cubic-bezier
    CustomEase.create("architectural", "0.4, 0, 0.2, 1");

    // Initialize Lenis — desktop only; native scroll is faster on iOS/Android
    const IS_MOBILE = window.innerWidth < 1024;

    let lenis;
    if (!IS_MOBILE) {
      lenis = new Lenis({
        lerp: 0.1,
        wheelMultiplier: 1,
        smoothWheel: true,
      });

      // Sync GSAP ScrollTrigger with Lenis
      lenis.on("scroll", ScrollTrigger.update);

      // Use requestAnimationFrame for Lenis to ensure instant input response
      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);
    }

    gsap.ticker.lagSmoothing(0);

    const tl = gsap.timeline({
      defaults: { ease: "power4.out", duration: 1.4, force3D: true },
    });

    // Explicitly apply will-change to elements before animation starts to hardware accelerate them
    gsap.set(
      [
        "#main-nav",
        ".hero-char",
        "#hero-title",
        "#hero-subtitle",
        "#hero-cta",
        ".service-card",
        "#selected-works",
        ".project-screenshot",
        ".tech-node",
        "#ambient-elements > div",
        ".advantage-card",
      ],
      { willChange: "transform, opacity" },
    );

    tl.to("#main-nav", { opacity: 1, y: 0, delay: 0.2 })
      .from(
        ".hero-char",
        {
          rotationX: 90,
          opacity: 0,
          y: 20,
          stagger: 0.05,
          duration: 1.0,
          ease: "power3.out",
          transformOrigin: "center bottom",
        },
        "-=1.1",
      )
      .to("#hero-title", { opacity: 1, y: 0 }, "-=0.8")
      .to("#hero-subtitle", { opacity: 1, y: 0 }, "-=1.1")
      .to("#hero-cta", { opacity: 1, y: 0 }, "-=1.1")
      .to(".tech-node", { opacity: 1, y: 0, stagger: 0.1 }, "-=1.0");

    // Advantage cards entrance
    gsap.to(".advantage-card", {
      scrollTrigger: { trigger: "#advantage", start: "top 85%" },
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power2.out",
      force3D: true,
    });

    // Bento tiles entrance
    gsap.to(".bento-tile", {
      scrollTrigger: { trigger: "#services", start: "top 80%" },
      opacity: 1,
      translate: "0px 0px",
      duration: 0.9,
      stagger: 0.12,
      ease: "power2.out",
      force3D: true,
    });

    // Floating animation for ambient tech elements — skip on mobile to save CPU
    if (!IS_MOBILE) {
      gsap.utils.toArray("#ambient-elements > div").forEach((element) => {
        gsap.to(element, {
          x: "random(-20, 20)",
          y: "random(-20, 20)",
          duration: "random(6, 10)",
          repeat: -1,
          yoyo: true,
          ease: "sine.inOut",
          force3D: true,
        });
      });

      // Floating orbit animation loop for tech nodes
      gsap.utils.toArray(".tech-node").forEach((node, i) => {
        gsap.to(node, {
          y: i % 2 === 0 ? 15 : -15,
          rotation: i % 2 === 0 ? 1 : -1,
          duration: 2.5 + i * 0.5,
          repeat: -1,
          yoyo: true,
          ease: "sine.inOut",
          force3D: true,
          delay: i * 0.2,
        });
      });
    }

    // Services Slide Animations
    gsap.to(".service-card", {
      scrollTrigger: { trigger: "#services", start: "top 80%" },
      opacity: 1,
      y: 0,
      duration: 1.2,
      stagger: 0.2,
      ease: "power2.out",
      force3D: true,
    });

    // ─── Selected Works: GSAP Pin on Desktop, Native Snap Scroll on Mobile ───
    const worksSection = document.querySelector("#selected-works");
    const pinWrap     = document.querySelector(".pin-wrap");

    if (worksSection && pinWrap) {
      if (!IS_MOBILE) {
        // DESKTOP: GSAP horizontal pin + scrub
        const worksTl = gsap.timeline({
          scrollTrigger: {
            trigger: worksSection,
            start: "top top",
            end: "+=500%",
            pin: true,
            scrub: 1,
            anticipatePin: 1,
            invalidateOnRefresh: true,
          },
        });

        worksTl.to(pinWrap, {
          x: () => -(pinWrap.scrollWidth - window.innerWidth),
          ease: "none",
        });

        // 1.2x parallax glide on futuristic blueprint terminals (desktop only)
        gsap.utils.toArray(".blueprint-terminal").forEach((terminal) => {
          worksTl.to(terminal, { x: -120, ease: "none" }, 0);
        });

        // Recalculate after layout settle
        window.addEventListener("load", () => {
          setTimeout(() => ScrollTrigger.refresh(), 800);
        });

        window.addEventListener("resize", () => ScrollTrigger.refresh());

      } else {
        // MOBILE: Native snap scroll logic
        pinWrap.setAttribute("data-lenis-prevent", "");
        
        // Remove GSAP pinning transforms if window was resized from desktop
        gsap.set(pinWrap, { clearProps: "all" });
      }
    }

    // Smooth Scroll Trigger for Hash Links using Lenis/Native
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        e.preventDefault();
        const targetId = anchor.getAttribute("href");
        if (targetId) {
          if (lenis) {
            lenis.scrollTo(targetId, {
              offset: 0,
              duration: 1.5,
              easing: (t) =>
                Math.min(
                  1,
                  1.001 *
                    Math.pow(2, -10 * t) *
                    Math.sin((t * 10 - 0.75) * ((2 * Math.PI) / 3)) +
                    1,
                ),
            });
          } else {
            // Mobile: native smooth scroll
            const targetElement = document.querySelector(targetId);
            if (targetElement) {
              targetElement.scrollIntoView({ behavior: "smooth" });
            }
          }
        }
      });
    });

    // Magnetic Hero Headline Letters — desktop only
    const heroChars = gsap.utils.toArray(".hero-char");
    if (heroChars.length > 0 && !IS_MOBILE) {
      let rafPending = false;
      let lastMouseX = 0, lastMouseY = 0;

      window.addEventListener("mousemove", (e) => {
        lastMouseX = e.clientX;
        lastMouseY = e.clientY;
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(() => {
          rafPending = false;
          heroChars.forEach((char) => {
            const rect = (char as HTMLElement).getBoundingClientRect();
            const charX = rect.left + rect.width / 2;
            const charY = rect.top + rect.height / 2;
            const distX = lastMouseX - charX;
            const distY = lastMouseY - charY;
            const distance = Math.sqrt(distX * distX + distY * distY);
            const magnetRadius = 100;

            if (distance < magnetRadius) {
              const pull = 1 - distance / magnetRadius;
              const moveX = (distX / distance) * pull * 10;
              const moveY = (distY / distance) * pull * 10;
              gsap.to(char, {
                x: moveX,
                y: moveY,
                rotationY: moveX * 0.5,
                rotationX: -moveY * 0.5,
                duration: 0.3,
                ease: "power2.out",
                overwrite: "auto",
              });
            } else {
              gsap.to(char, {
                x: 0,
                y: 0,
                rotationY: 0,
                rotationX: 0,
                duration: 0.6,
                ease: "power3.out",
                overwrite: "auto",
              });
            }
          });
        });
      });
    }

    // Section Tracer Border Animation
    gsap.utils.toArray(".section-tracer-target").forEach((section) => {
      const tracer = (section as HTMLElement).querySelector(".section-tracer");
      if (tracer) {
        gsap.to(tracer, {
          scaleX: 1,
          duration: 1.2,
          ease: "power3.inOut",
          force3D: true,
          scrollTrigger: {
            trigger: section as HTMLElement,
            start: "top 85%",
            toggleActions: "play none none reverse",
          },
        });
      }
    });

    // Hero Background Subtle Entrance
    const heroBg = document.querySelector("#hero-background");
    if (heroBg) {
      gsap.from(heroBg, {
        opacity: 0,
        scale: 0.95,
        duration: 3,
        delay: 1,
        ease: "power2.out",
      });
    }

    // ─── Contact Form Feedback System ─────────────────────────────────────
    const contactForm = document.getElementById("contact-form") as HTMLFormElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const successEl = document.getElementById("form-success");
    const errorEl = document.getElementById("form-error");

    if (contactForm && submitBtn) {
      contactForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        
        // Reset states
        successEl?.classList.add("hidden");
        errorEl?.classList.add("hidden");

        // Button loading state
        const originalText = submitBtn.textContent;
        submitBtn.textContent = "Sending...";
        submitBtn.disabled = true;
        submitBtn.style.opacity = "0.7";
        submitBtn.style.cursor = "wait";

        try {
          // TODO: Replace this with your actual backend endpoint
          // Example: await fetch('/api/contact', { method: 'POST', body: formData });
          await new Promise(resolve => setTimeout(resolve, 1200));

          // Show success state
          successEl?.classList.remove("hidden");
          
          // Hide form fields with animation
          const formFields = contactForm.querySelectorAll("input, textarea, .grid, .flex.flex-col.mt-2, .mt-6.flex");
          formFields.forEach(el => {
            (el as HTMLElement).style.transition = "opacity 0.4s ease, transform 0.4s ease";
            (el as HTMLElement).style.opacity = "0.3";
            (el as HTMLElement).style.pointerEvents = "none";
          });

          // Update button
          submitBtn.textContent = "✓ Sent";
          submitBtn.style.opacity = "1";
          submitBtn.style.background = "#253644";
          submitBtn.style.color = "#5DFFEC";
          
          // Reset form after delay
          setTimeout(() => {
            contactForm.reset();
            formFields.forEach(el => {
              (el as HTMLElement).style.opacity = "1";
              (el as HTMLElement).style.pointerEvents = "auto";
            });
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
            submitBtn.style.cursor = "pointer";
            submitBtn.style.background = "";
            submitBtn.style.color = "";
            successEl?.classList.add("hidden");
          }, 5000);

        } catch (err) {
          // Show error state
          errorEl?.classList.remove("hidden");
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
          submitBtn.style.opacity = "1";
          submitBtn.style.cursor = "pointer";
        }
      });
    }
  </script>

