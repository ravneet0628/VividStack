---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout
  title="Terms of Service"
  description="Terms for using the VividStack website. Project-specific agreements may add or replace these where signed."
>
  <Navbar />
  <main id="main-content" class="bg-vivid-cream text-vivid-navy min-h-screen pt-24 pb-20">
    <article class="max-w-3xl mx-auto px-6">
      <p class="text-vivid-mint font-bold uppercase tracking-[0.35em] text-xs mb-4">Legal</p>
      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-tight mb-10" style="font-family: 'Space Grotesk', sans-serif;">
        Terms of Service
      </h1>
      <div class="space-y-6 text-vivid-navy/85 leading-relaxed" style="font-family: 'Inter', sans-serif;">
        <p class="text-sm text-vivid-navy/60">Last updated: April 3, 2026</p>
        <p>
          These terms apply to your use of vividstack.ca. Engaging us for design or development work is governed by a
          separate proposal or contract; where that document conflicts with this page, the signed agreement wins.
        </p>
        <h2 class="text-lg font-bold uppercase tracking-wide text-vivid-navy pt-4">Use of the site</h2>
        <p>
          Content on this site is for general information about our agency. Do not rely on it as legal, financial, or
          technical advice for your business without speaking to us directly.
        </p>
        <h2 class="text-lg font-bold uppercase tracking-wide text-vivid-navy pt-4">Intellectual property</h2>
        <p>
          Unless otherwise noted, text, visuals, and layout on this site are owned by VividStack or used with
          permission. Please do not copy or redistribute our portfolio or branding without consent.
        </p>
        <h2 class="text-lg font-bold uppercase tracking-wide text-vivid-navy pt-4">Limitation of liability</h2>
        <p>
          We aim to keep this site accurate and available, but we are not liable for indirect or consequential damages
          arising from your use of the site or from temporary outages.
        </p>
        <h2 class="text-lg font-bold uppercase tracking-wide text-vivid-navy pt-4">Changes</h2>
        <p>
          We may update these terms occasionally. The “Last updated” date at the top reflects the latest revision.
        </p>
        <p class="pt-8">
          <a
            href="/"
            class="font-bold uppercase tracking-widest text-xs text-vivid-navy border-b-2 border-vivid-mint hover:text-vivid-mint transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vivid-navy focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-cream rounded-sm"
            >← Back to home</a>
        </p>
      </div>
    </article>
  </main>
</Layout>
