---
import "../styles/global.css";
import { getImage } from "astro:assets";
import defaultOgSrc from "../assets/Vivid-stack-logo.png";

interface Props {
  title?: string;
  description?: string;
  /** Site-root path (e.g. `/photo.jpg`) or absolute URL; defaults to optimized navbar logo */
  ogImage?: string;
}

const {
  title = "Premium Web Design & Development Agency",
  description = "Fast, mobile-ready websites for shops, trades, and service businesses—look professional, get found on Google, and keep ongoing costs low.",
  ogImage: ogImageProp,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://vividstack.io");

const defaultOg = await getImage({
  src: defaultOgSrc,
  width: 1200,
  format: "png",
});

const ogImageUrl = ogImageProp
  ? ogImageProp.startsWith("http://") || ogImageProp.startsWith("https://")
    ? ogImageProp
    : new URL(ogImageProp.startsWith("/") ? ogImageProp : `/${ogImageProp}`, canonicalURL.origin).href
  : new URL(defaultOg.src, canonicalURL.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | VividStack`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | VividStack`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: preconnect first, then load with swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Space+Grotesk:wght@300..700&family=Inter:wght@400;500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Space+Grotesk:wght@300..700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Space+Grotesk:wght@300..700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    </noscript>

    <meta name="generator" content={Astro.generator} />
    <title>{title} | VividStack</title>
  </head>

  <body class="antialiased bg-vivid-cream text-vivid-navy selection:bg-vivid-teal selection:text-vivid-navy">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10000] focus:inline-flex focus:items-center focus:min-h-[48px] focus:px-6 focus:py-3 focus:bg-vivid-navy focus:text-vivid-teal focus:font-bold focus:uppercase focus:tracking-[0.2em] focus:text-xs focus:shadow-brutalist-navy-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-vivid-teal focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-navy"
    >
      Skip to content
    </a>
    <slot />
    <!-- Web3Forms: load after idle or first focus on the form (smaller critical path) -->
    <script is:inline>
      (function () {
        var loaded = false;
        function loadWeb3Forms() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement("script");
          s.src = "https://web3forms.com/client/script.js";
          s.async = true;
          document.body.appendChild(s);
        }
        var form = document.getElementById("contact-form");
        if (form) form.addEventListener("focusin", loadWeb3Forms, { once: true, passive: true });
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadWeb3Forms, { timeout: 6000 });
        } else {
          setTimeout(loadWeb3Forms, 4000);
        }
      })();
    </script>
  </body>
</html>