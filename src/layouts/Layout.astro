---
import "../styles/global.css";
import { getImage } from "astro:assets";
import defaultOgSrc from "../assets/Vivid-stack-logo.png";

interface Props {
  title?: string;
  description?: string;
  /** Site-root path (e.g. `/photo.jpg`) or absolute URL; defaults to optimized navbar logo */
  ogImage?: string;
  /** When true, adds robots noindex (e.g. 404 page). */
  noindex?: boolean;
}

const {
  title = "Fast web design for local businesses",
  description = "Fast, mobile-ready websites for shops, trades, and service businesses. Look professional, get found on Google, and keep ongoing costs low.",
  ogImage: ogImageProp,
  noindex = false,
} = Astro.props;

const siteOrigin = "https://vividstack.ca";
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const documentTitle = `VividStack | ${title}`;

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteOrigin}/#website`,
      url: siteOrigin,
      name: "VividStack",
      description:
        "Fast, mobile-ready websites for shops, trades, and service businesses. Look professional, get found on Google, and keep ongoing costs low.",
      publisher: { "@id": `${siteOrigin}/#organization` },
      inLanguage: "en-US",
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteOrigin}/#organization`,
      name: "VividStack",
      url: siteOrigin,
      description:
        "Web design and development for local businesses: fast builds, mobile-ready layouts, and SEO-friendly structure.",
      serviceType: ["Web design", "Web development", "Website maintenance"],
      areaServed: { "@type": "Country", name: "United States" },
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalURL.href}#webpage`,
      url: canonicalURL.href,
      name: documentTitle,
      description,
      isPartOf: { "@id": `${siteOrigin}/#website` },
      inLanguage: "en-US",
    },
  ],
});

const defaultOg = await getImage({
  src: defaultOgSrc,
  width: 1200,
  format: "png",
});

const favicon32 = await getImage({
  src: defaultOgSrc,
  width: 32,
  height: 32,
  format: "png",
});

const appleTouchIcon = await getImage({
  src: defaultOgSrc,
  width: 180,
  height: 180,
  format: "png",
});

const ogImageUrl = ogImageProp
  ? ogImageProp.startsWith("http://") || ogImageProp.startsWith("https://")
    ? ogImageProp
    : new URL(ogImageProp.startsWith("/") ? ogImageProp : `/${ogImageProp}`, canonicalURL.origin).href
  : new URL(defaultOg.src, canonicalURL.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="VividStack" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: preconnect first, then load with swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Space+Grotesk:wght@300..700&family=Inter:wght@400;500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Space+Grotesk:wght@300..700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="(function(l){l.media='all'})(this)"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Space+Grotesk:wght@300..700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Turnstile loads when #contact is near view; warm TLS -->
    <link rel="preconnect" href="https://challenges.cloudflare.com" crossorigin />

    <meta name="generator" content={Astro.generator} />
    <title>{documentTitle}</title>
    {!noindex && <script type="application/ld+json" is:inline set:html={structuredData} />}
  </head>

  <body class="antialiased bg-vivid-cream text-vivid-navy selection:bg-vivid-teal selection:text-vivid-navy">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10000] focus:inline-flex focus:items-center focus:min-h-[48px] focus:px-6 focus:py-3 focus:bg-vivid-navy focus:text-vivid-teal focus:font-bold focus:uppercase focus:tracking-[0.2em] focus:text-xs focus:shadow-brutalist-navy-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-vivid-teal focus-visible:ring-offset-2 focus-visible:ring-offset-vivid-navy"
    >
      Skip to content
    </a>
    <slot />
    <!-- Cloudflare Turnstile: load only when #contact is near/in view (avoids third-party work on first paint) -->
    <script is:inline>
      (function () {
        var loaded = false;
        function loadTurnstile() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement("script");
          s.src = "https://challenges.cloudflare.com/turnstile/v0/api.js";
          s.async = true;
          s.defer = true;
          document.body.appendChild(s);
        }
        var contactSection = document.getElementById("contact");
        if (!contactSection) return;
        if ("IntersectionObserver" in window) {
          var io = new IntersectionObserver(
            function (entries) {
              var i, entry;
              for (i = 0; i < entries.length; i++) {
                entry = entries[i];
                if (entry.isIntersecting) {
                  loadTurnstile();
                  io.disconnect();
                  return;
                }
              }
            },
            { rootMargin: "200px 0px", threshold: 0.01 }
          );
          io.observe(contactSection);
        } else {
          loadTurnstile();
        }
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          if (sessionStorage.getItem("vs-dev-hi")) return;
          sessionStorage.setItem("vs-dev-hi", "1");
          var navy = "#253644";
          var mint = "#95CBD0";
          console.log(
            "%cVividStack%c This site is static-first and built for speed. Curious about the stack? Say hi at vividstack.ca.",
            "font-weight:700;color:" + mint + ";",
            "color:" + navy + ";",
          );
        } catch (_) {}
      })();
    </script>
  </body>
</html>